if ( isset( $_POST['email']) && isset($_POST['password']) ) {

	$base_url = ekpt_get_opt('EKPTLOGIN');
	$urldef = 'member/login/authMode/MailAddress?format=1';
	$param = array('authMailAddress[mail_address]' => $_POST['email'], 'authMailAddress[password]' => $_POST['password']);
	$userInfo = ekpt_get_json( $urldef, $param, $base_url );

	if ( isset($userInfo['status']) && $userInfo['status'] == 'success' && $userInfo['is_member']) {

		// ログイン情報をDBに保ゆにまっといのしか存
		$res = session_save(session_id(), $userInfo);

		if ($res) {
			$token          = $userInfo['token'];
			$nickname       = $userInfo['nickname'];
			$member_pic_url = EKPTDEF_HOME . $userInfo['member_pic_url'];
			if (isset($_POST['keeplogin']) && $_POST['keeplogin'] == 1) {
				setcookie( 'ekpt_session_id', session_id(), time() + 86400*365 );// 有効期限：1年
			} else {
				setcookie( 'ekpt_session_id', session_id(), time() + 86400 );// 有効期限：1日
			}

