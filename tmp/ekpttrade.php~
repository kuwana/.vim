	public function get_memitemboxown_trade() {

	    global $json_api;

		extract($json_api->query->get(array('mem_id', 'item_type', 'item_cate', 'offset', 'limit', 'seq_no')));
		if (!$mem_id) {
			$params = $json_api->introspector->get_posts(array(
			'mem_id' => $mem_id,
			'item_type' => $item_type,
			'item_cate' => $item_cate,
			'offset' => $offset,
			'limit' => $limit,
			'seq_no' => $seq_no
		));
		}

		$memitemboxowns = $json_api->ekptgfis->get_memitemboxowns($mem_id, $item_type, $item_cate);
		$count = count($memitemboxowns);
		$clabel = '';
		//$limdatas = array('selecteditems' => '', 'subcount' => '', 'subitems' => '');
		foreach ($memitemboxowns as $val) {
			if ($clabel != $val->category_label) {
				$clabel = $val->category_label;
			}
			if (strpos($seq_no, (string)$val->seq_no) !== false) {
				$limdatas['selecteditems'][] = $val;
				continue;
			}
			$spdatas[$clabel][] = $val;
		}
		foreach ($spdatas as $val) {
			$limdatas['subcount'][] = count($val);
			$limdatas['subitems'][] = array_slice($val, $offset, $limit);
		}

		return array(
			'count' => $count,
			'memitemboxowns' => $limdatas
		);

	}
