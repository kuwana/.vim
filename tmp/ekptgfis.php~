	 * 交換BOXの交換申込を取り下げる
	 */
	public function cancel_apply_tradebox($apply_seq_nos = '', $comment = '') {

		global $wpdb;
		global $json_api;

		if ($apply_seq_nos) {
			// キャンセル可能かチェックし、可能な番号のみ取得する
			$query_param = str_replace(',', ' OR tradebox_item_seq_no = ', $apply_seq_nos);
			$query = "SELECT tradebox_item_seq_no FROM ekptgf_tradebox_apply WHERE status = 'a' AND tradebox_item_seq_no =";
			$query .= $wpdb->escape($query_param);
			$enabled_cancel_nos = $wpdb->get_col($query);
		} else {
			$enabled_cancel_nos = $apply_seq_nos;
		}
		$mem_id = $wpdb->get_var($wpdb->prepare("
			SELECT mem_id FROM ekptgf_tradebox_apply WHERE seq_no = %d"
			, $enabled_cancel_nos[0]));

		// 交換申込を取り下げる
		foreach ($enabled_cancel_nos as $cancel_no) {

			$status = 'C';
			// 交換申込TBLの更新
			$query = $wpdb->prepare("
				UPDATE ekptgf_tradebox_apply SET status = %s WHERE seq_no = %d
				", $status, $cancel_no);
			$res = $wpdb->query($query);

			// 申請した所有アイテムのseq_noを取得
			$query = $wpdb->prepare("
				SELECT mem_item_own_seq_no FROM ekptgf_tradebox_apply_det WHERE tradebox_apply_seq_no = %d
				", $cancel_no);
			$items_seqs = $wpdb->get_col($query);

			// 所有アイテムのステータスを変更
			$status = 'U';
			foreach ($items_seqs as $seq) {

				$query = $wpdb->prepare("
					UPDATE ekptgf_mem_item_own SET status = %s WHERE seq_no = %d
					", $status, $seq);
				$res = $wpdb->query($query);

			}

		}

		if ($res) {
			// キャンセル後の会員の出品一覧の取得
			$items[] = $this->get_mem_apply_tradebox_list($mem_id);
		} else {
			$json_api->error('update is failed');
		}

		return $items;

	}

	/**
	 * 交換BOXトレードの実行
	 */
	public function exec_tradebox_item($seq_no = 0) {

		global $wpdb;
		global $json_api;

		$items = array();

		// ------------------------------------
		// tradebox_itemのseq_noを元に、
		// 交換を行う所有アイテムのseq_noを取得
		// ------------------------------------

		// 出品アイテムのseq_noを取得
		$send_own_seq_nos = $wpdb->get_col($wpdb->prepare("
			SELECT tbid.mem_item_own_seq_no
			FROM ekptgf_tradebox_item tbi
			INNER JOIN ekptgf_tradebox_item_det tbid
			ON tbi.seq_no = tbid.tradebox_item_seq_no
			WHERE tbi.seq_no = %d
			", $seq_no));

		// 申請アイテムのseq_noを取得
		$apply_own_seq_nos = $wpdb->get_col($wpdb->prepare("
			SELECT tbad.mem_item_own_seq_no
			FROM ekptgf_tradebox_apply tba
			INNER JOIN ekptgf_tradebox_apply_det tbad
			ON tba.seq_no = tbad.tradebox_apply_seq_no
			WHERE tba.tradebox_item_seq_no = %d
		", $seq_no));

		// ------------------------------
		// 両者の所有アイテムの交換を行う
		// ------------------------------

		// 申請アイテムの所有者IDとマスターアイテムIDを取得
		$query = 'SELECT mem_id, item_id FROM ekptgf_mem_item_own';
		$query .= ' WHERE seq_no IN ('. implode(',', $apply_own_seq_nos) .')';
		$apply_items = $wpdb->get_results($wpdb->prepare($query));

		// 出品アイテムの所有者IDとマスターアイテムIDを取得
		$query = 'SELECT mem_id, item_id FROM ekptgf_mem_item_own';
		$query .= ' WHERE seq_no IN (' . implode(',', $send_own_seq_nos) .')';
		$send_items = $wpdb->get_results($wpdb->prepare($query));

		// 申請者の所有アイテムに出品アイテムを追加
		foreach ($send_items as $sitem) {
			$memitem_a = $this->add_memitemown($apply_items[0]->mem_id, $sitem->item_id);
		}
		if ( count($memitem_a) == 0 ) { $json_api->error("Error add_memitemown."); }
		$items[] = $memitem_a;

		// 出品者の所有アイテムに申請アイテムを追加
		foreach ($apply_items as $aitem) {
			$memitem_s = $this->add_memitemown($send_items[0]->mem_id, $aitem->item_id);
		}
		if ( count($memitem_s) == 0 ) { $json_api->error("Error add_memitemown."); }
		$items[] = $memitem_s;

		// ------------------------
		// 各ステータスの変更を行う
		// ------------------------

		// 出品完了にする
		$status = "S" ;
		$query = $wpdb->prepare("
			UPDATE ekptgf_tradebox_item SET status = %s, modified = now() WHERE seq_no = %d", $status, $seq_no) ;
		$res = $wpdb->query( $query );
		if ( !$res ) { $json_api->error("Error update tradebox_item status."); }

		// 申請完了にする
		$status = "A" ;
		$query = $wpdb->prepare("
			UPDATE ekptgf_tradebox_apply SET status = %s, modified = now() WHERE tradebox_item_seq_no = %d", $status, $seq_no ) ;
		$res = $wpdb->query( $query );
		if ( !$res ) { $json_api->error("Error update tradebox_item status."); }

		// 出品者の所有アイテムを使用不可にする
		$status = "D" ;
		foreach ($send_own_seq_nos as $seq) {
			$query = $wpdb->prepare("
				UPDATE ekptgf_mem_item_own SET status = %s, modified = now() WHERE seq_no = %d"
				, $status, $seq);
			$res = $wpdb->query( $query );

			if ( !$res ) { $json_api->error("Error update apply_own_item status."); }
		}

		// 申請者の所有アイテムを使用不可にする
		$status = "D" ;
		foreach ($apply_own_seq_nos as $seq) {
			$query = $wpdb->prepare("
				UPDATE ekptgf_mem_item_own SET status = %s, modified = now() WHERE seq_no = %d"
				, $status, $seq);
			$res = $wpdb->query( $query );

			if ( !$res ) { $json_api->error("Error update apply_own_item status."); }
		}

		// 他の申請を不成立にする
		$status = "C" ;
		$query = $wpdb->prepare("
			UPDATE ekptgf_tradebox_apply SET status = %s, modified = now() WHERE tradebox_item_seq_no = %d AND mem_id <> %d"
			, $status, $seq_no, $apply_items[0]->mem_id) ;
		$res = $wpdb->query( $query );

		return $items;
	}

