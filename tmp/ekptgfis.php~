	public function reply_trade_apply($seq_no, $reply) {

		global $wpdb;

		if ($reply == 'no') {
			$status = 'C';
			$query = $wpdb->prepare("
				UPDATE ekptgf_trade_apply SET status = %s WHERE trade_item_seq_no = %d", $status, $seq_no);
			$res = $wpdb->query( $query );
			if ( !$res ) {
				$json_api->error("Error update trade_apply status.");
			}
			$sender_item = $wpdb->get_row($wpdb->prepare("
				SELECT * FROM ekptgf_trade_apply WHERE seq_no = %d
				", $seq_no));
		}
		$items = array();
		$items[] = $this->get_mem_trade_item_list($sender_item->mem_id);

		return $items;
	}

