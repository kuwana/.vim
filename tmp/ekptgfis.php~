	 */
	public function send_tradebox_item($tbox_seqs = '', $to_mem_id = null, $tbox_title = '', $tbox_desc = '', $tbox_msg) {

		global $wpdb;
		global $json_api;

		$status = 's';  // ステータス：出品中
		if ($tbox_seqs) { // seq_noの指定が存在する場合

			$seqs = explode(',', $tbox_seqs);
			$from_mem_id = $wpdb->get_var($wpdb->prepare("SELECT mem_id FROM ekptgf_mem_item_own WHERE seq_no = %d"
				, $seqs[0]));

			// 交換BOX出品TBLへ挿入
		    $query = $wpdb->prepare("
				INSERT INTO ekptgf_tradebox_item
					(tradebox_no, from_mem_id, to_mem_id, status, tradebox_title, tradebox_desc, created)
				VALUES(%d, %d, %d, %s, %s, %s, now())", 0, $from_mem_id, $to_mem_id, $status, $tbox_title, $tbox_desc);
			$res = $wpdb->query( $query );
	        $last_id = $wpdb->get_var($wpdb->prepare("SELECT LAST_INSERT_ID() as last_id"));

		} else { // seq_noの指定が存在しない場合

			$seqs = array();

		}

		// 出品者メッセージの挿入
		if ($tbox_msg) {

			$query = $wpdb->prepare("
				INSERT INTO ekptgf_trade_item_comment
					('trade_item_seq_no', 'mem_id', 'trade_comment', 'created')
				VALUES(%d, %d, %s, now())", $last_id, $mem_id, $tbox_msg);
			$res = $wpdb->query( $query );

		}

		$status = 'S';
		foreach ($seqs as $seq) {
			// 交換BOX出品明細TBLへ挿入
		    $query = $wpdb->prepare("
				INSERT INTO ekptgf_tradebox_item_det
					(tradebox_item_seq_no, mem_item_own_seq_no, created)
				VALUES(%d, %d, now())", $last_id, $seq);
			$res = $wpdb->query( $query );

			// 所有アイテムのステータスを変更
			$query = $wpdb->prepare("
				UPDATE ekptgf_mem_item_own SET status = %s WHERE seq_no = %d
				", $status, $seq);
			$res = $wpdb->query($query);

		}

		$items = array();
		if ($res) {
			$items = $this->get_tradebox_item_list($from_mem_id);
		} else {
			$json_api->error("insert is failed.");
		}

		return $items;

	}

