	/**
	 * 出品を取り下げる
	 */
	public function cancel_trade_item($trade_seq = '', $comment = '') {

		global $wpdb;
		global $json_api;

		$items = array();
		// ------------------------------------
		// trade_itemのseq_noを元に、
		// 交換を行う所有アイテムのseq_noを取得
		// ------------------------------------
		// 出品アイテムのseq_noを取得
		$send_own_seq_nos = $apply_own_seq_nos = array() ;
		$send_own_seq_nos = $wpdb->get_col($wpdb->prepare("
			SELECT tid.mem_item_own_seq_no
			FROM ekptgf_trade_item ti
			INNER JOIN ekptgf_trade_item_det tid
			ON ti.seq_no = tid.trade_item_seq_no
			WHERE ti.seq_no = %d
			", $trade_seq));
		if ( !$send_own_seq_nos) {
			$json_api->error("cancel_trade_item - get trade items error.");
		}
		// 申請アイテムのseq_noを取得
		$apply_own_seq_nos = $wpdb->get_col($wpdb->prepare("
			SELECT tad.mem_item_own_seq_no
			FROM ekptgf_trade_apply ta
			INNER JOIN ekptgf_trade_apply_det tad
			ON ta.seq_no = tad.trade_apply_seq_no
			WHERE ta.trade_item_seq_no = %d
		", $trade_seq));
		// 出品を取り下げる
		$status = 'C';
		// 出品TBLの更新
		$query = $wpdb->prepare("
			UPDATE ekptgf_trade_item SET status = %s, modified = now() WHERE seq_no = %d
			", $status, $trade_seq);
		$res = $wpdb->query($query);

		// 交換申込TBLの更新
		$query = $wpdb->prepare("
			UPDATE ekptgf_trade_apply SET status = %s, modified = now() WHERE trade_item_seq_no = %d
			", $status, $trade_seq);
		$res = $wpdb->query($query);
		// 出品アイテムのseq_noを取得
		$query = $wpdb->prepare("
			SELECT mem_item_own_seq_no FROM ekptgf_trade_item_det WHERE trade_item_seq_no = %d
			", $trade_seq);
		$item_seqs = $wpdb->get_col($query);
		// 所有アイテムのステータスを変更
		$status = 'U';
		foreach ($send_own_seq_nos as $seq) {
			$query = $wpdb->prepare("
				UPDATE ekptgf_mem_item_own SET status = %s, modified = now() WHERE seq_no = %d
				", $status, $seq);
			$res = $wpdb->query($query);
		}
		foreach ($apply_own_seq_nos as $seq) {
			$query = $wpdb->prepare("
				UPDATE ekptgf_mem_item_own SET status = %s, modified = now() WHERE seq_no = %d
				", $status, $seq);
			$res = $wpdb->query($query);
		}		
		if ($res) {
			// キャンセル後の会員の出品一覧の取得
			$items[] = $this->get_mem_trade_item_list($mem_id);
		} else {
			$items = array() ;
		}
		return $items;
	}
	/**
	 * 交換申込を取り下げる
	 */
	public function cancel_apply_trade($apply_seq_nos = '', $comment = '') {

		global $wpdb;
		global $json_api;
		if ($apply_seq_nos) {
			// キャンセル可能かチェックし、可能な番号のみ取得する
			$query_param = str_replace(',', ' OR seq_no = ', $apply_seq_nos);
			$query = "SELECT seq_no FROM ekptgf_trade_apply WHERE status = 'A' AND seq_no =";
			$query .= $wpdb->escape($query_param);
			$enabled_cancel_nos = $wpdb->get_col($query);
			$mem_id = $wpdb->get_var($wpdb->prepare("
				SELECT mem_id FROM ekptgf_trade_apply WHERE seq_no = %d"
				, $enabled_cancel_nos[0]));
		} else {
			$enabled_cancel_nos = array();
		}

		// 交換申込を取り下げる
		foreach ($enabled_cancel_nos as $cancel_no) {
			$status = 'C';
			// 交換申込TBLの更新
			$query = $wpdb->prepare("
				UPDATE ekptgf_trade_apply SET status = %s, modified = now() WHERE seq_no = %d
				", $status, $cancel_no);
			$res = $wpdb->query($query);
			// 申請アイテムのseq_noを取得
			$query = $wpdb->prepare("
				SELECT mem_item_own_seq_no FROM ekptgf_trade_apply_det WHERE trade_apply_seq_no = %d
				", $cancel_no);
			$item_seqs = $wpdb->get_col($query);
			// 所有アイテムのステータスを変更
			$status = 'U';
			foreach ($item_seqs as $seq) {
				$query = $wpdb->prepare("
					UPDATE ekptgf_mem_item_own SET status = %s, modified = now() WHERE seq_no = %d
					", $status, $seq);
				$res = $wpdb->query($query);
			}
		}

		if ($res) {
			// キャンセル後の会員の出品一覧の取得
			$items[] = $this->get_mem_apply_trade_list($mem_id);
		} else {
			$items = array() ;
		}

		return $items;

	}
    
	/**
	 * 交換申込を取り下げる
	 */
	public function reject_apply_trade($apply_seq_nos = '', $comment = '') {

		global $wpdb;
		global $json_api;
		if ($apply_seq_nos) {
			// キャンセル可能かチェックし、可能な番号のみ取得する
			$query_param = str_replace(',', ' OR seq_no = ', $apply_seq_nos);
			$query = "SELECT seq_no FROM ekptgf_trade_apply WHERE status = 'A' AND seq_no =";
			$query .= $wpdb->escape($query_param);
			$enabled_cancel_nos = $wpdb->get_col($query);
			$mem_id = $wpdb->get_var($wpdb->prepare("
				SELECT mem_id FROM ekptgf_trade_apply WHERE seq_no = %d"
				, $enabled_cancel_nos[0]));
		} else {
			$enabled_cancel_nos = array();
		}

		// 交換申込を取り下げる
		foreach ($enabled_cancel_nos as $cancel_no) {
			$status = 'R';
			// 交換申込TBLの更新
			$query = $wpdb->prepare("
				UPDATE ekptgf_trade_apply SET status = %s, modified = now() WHERE seq_no = %d
				", $status, $cancel_no);
			$res = $wpdb->query($query);
			// 申請アイテムのseq_noを取得
			$query = $wpdb->prepare("
				SELECT mem_item_own_seq_no FROM ekptgf_trade_apply_det WHERE trade_apply_seq_no = %d
				", $cancel_no);
			$item_seqs = $wpdb->get_col($query);
			// 所有アイテムのステータスを変更
			$status = 'U';
			foreach ($item_seqs as $seq) {
				$query = $wpdb->prepare("
					UPDATE ekptgf_mem_item_own SET status = %s , modified = now() WHERE seq_no = %d
					", $status, $seq);
				$res = $wpdb->query($query);
			}
		}

		if ($res) {
			// キャンセル後の会員の出品一覧の取得
			$items[] = $this->get_mem_apply_trade_list($mem_id);
		} else {
			$items = array() ;
