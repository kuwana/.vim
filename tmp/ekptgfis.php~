  public function exec_memgacya( $seq_no ) {
    global $wpdb;
    global $json_api ;
	$item_id_by_draw = 0;
	$num_of_item = 0;
	$debug_flag = false;
	// 合計値取得
	if ( $debug_flag ) { echo '<br>Start 1 exec_memgacya seq_no='.$seq_no ; }
    // 基本アイテムを取得
    $base_info = $wpdb->get_row($wpdb->prepare("SELECT * from ekptgf_mem_gacya where seq_no = %d", $seq_no));
    if ( $base_info->status <> "U" ) {
            $json_api->error("Error gacya status is invalid. status=".$base_info->status);
    }
	// 抽選機能実行
	$wp_gacya_draws =  $wpdb->get_results($wpdb->prepare("
      SELECT * 
	  FROM ekptgf_m_gacya_draw 
	  WHERE gacya_id = %d 
	  ORDER BY frequency desc
	", $base_info->gacya_id));
	$wp_gacya_draw_sum = $wpdb->get_row($wpdb->prepare("SELECT sum(frequency) sumoffreq from ekptgf_m_gacya_draw WHERE gacya_id = %d", $base_info->gacya_id ));
	$rand = rand(1,$wp_gacya_draw_sum->sumoffreq);
	$total = 0;
	foreach( $wp_gacya_draws as $wp_gacya_draw) {
	  $total += $wp_gacya_draw->frequency ;
	  if ($rand <= $total) {
	    $item_id_by_draw = $wp_gacya_draw->item_id;
		$num_of_item = $wp_gacya_draw->num_of_item ;
	    break;
	  }
	}
	// 合計値取得
	if ( $debug_flag ) { echo '<br>Start 2 exec_memgacya seq_no='.$seq_no ; }
	// アイテムの情報を取得
	$base_item_info = $wpdb->get_row($wpdb->prepare("SELECT * from ekptgf_m_item where item_id = %d", $item_id_by_draw));
    // 個数を求める
