	/**
	 * アイテムを出品する
	 */
	public function send_trade_item($trade_seq_nos = '', $trade_title = '', $trade_desc = '') {

		global $wpdb;
		global $json_api;
        $trade_msg = '' ;
		$items = array();
		$tradestatus = 'S';  // ステータス：出品中
		if (empty($trade_seq_nos)) { // seq_noの指定が存在しない場合
			$json_api->error("send_trade_item - No data found.");
			return $items;
		} else { // seq_noの指定が存在する場合
			$seqs = explode(',', $trade_seq_nos);
            foreach ( $seqs as $seq ) {
               $current = $wpdb->get_row($wpdb->prepare("SELECT * FROM ekptgf_mem_item_own WHERE seq_no = %d"
                   , $seq));
               if ( $current == -1 ) {
                  $json_api->error("send_trade_item - No own data found.");
                  return $items;                  
               }
               if ( $current->status <> 'U' or  $current->comp_status <> 'O' ) {
                  $json_api->error("選ばれたアイテムは、装備中または、ベースアイテム指定されています。");
                  return $items;                  
               }
            }
			$mem_id = $wpdb->get_var($wpdb->prepare("SELECT mem_id FROM ekptgf_mem_item_own WHERE seq_no = %d"
				, $seqs[0]));
			// 出品TBLへ挿入
			$query = $wpdb->prepare("
				INSERT INTO ekptgf_trade_item
					(trade_no, mem_id, status, trade_title, trade_desc, created)
				VALUES(%d, %d, %s, %s, %s, now())", 0, $mem_id, $tradestatus, $trade_title, $trade_desc);
			$res = $wpdb->query( $query );
			if ( !$res ) {
				$json_api->error("send_trade_item - - ekptgf_trade_item insert is failed.");
				return $items;
			}
		    $last_id = $wpdb->get_var($wpdb->prepare("SELECT LAST_INSERT_ID() as last_id"));
		}
		// 出品者メッセージの挿入
		if ( $trade_msg <> '' ) {
			$query = $wpdb->prepare("
				INSERT INTO ekptgf_trade_item_comment
					('trade_item_seq_no', 'mem_id', 'trade_comment', 'created')
				VALUES(%d, %d, %s, now())", $last_id, $mem_id, $trade_msg);
			$resIns = $wpdb->query( $query );
			if ( !$resIns ) {
				$json_api->error("send_trade_item - - ekptgf_trade_item_comment insert is failed.");
				return $items;
			}
		}
		$status = 'T';
		foreach ($seqs as $seq) {
			// 出品明細TBLへ挿入
		    $query = $wpdb->prepare("
				INSERT INTO ekptgf_trade_item_det
					(trade_item_seq_no, mem_item_own_seq_no, created)
				VALUES(%d, %d, now())", $last_id, $seq);
			$res = $wpdb->query( $query );
			if ( !$res ) {
				$json_api->error("send_trade_item - insert ekptgf_trade_item_det is failed.");
				return $items;
			}
			// 所有アイテムのステータスを変更
			$query = $wpdb->prepare("
				UPDATE ekptgf_mem_item_own SET status = %s, modified = now() WHERE seq_no = %d
				", $status, $seq);
			$res = $wpdb->query($query);
		}
		$items = array() ;
		$items = $this->get_trade_item_list_by_seqno($last_id);
		return $items;

	}
	/**
	 * 交換申込を行う
	 */
	public function apply_trade_item($trade_seq_no = 0, $item_seqs = '', $comment = '') {
		global $wpdb;
		global $json_api;
		$status = 'A';  // ステータス：申込中
		if ($item_seqs) {
			$seqs = explode(',', $item_seqs);
            foreach ( $seqs as $seq ) {
               $current = $wpdb->get_row($wpdb->prepare("SELECT * FROM ekptgf_mem_item_own WHERE seq_no = %d"
                   , $seq));
               if ( $current == -1 ) {
                  $json_api->error("send_trade_item - No own data found.");
                  return $items;                  
               }
               if ( $current->status <> 'U' or  $current->comp_status <> 'O' ) {
                  $json_api->error("選ばれたアイテムは、装備中または、ベースアイテム指定されています。");
                  return $items;                  
               }
            }
			$mem_id = $wpdb->get_var($wpdb->prepare("
				SELECT mem_id FROM ekptgf_mem_item_own WHERE seq_no = %d"
				, $seqs[0]));
			$last_id = $wpdb->get_var($wpdb->prepare("SELECT LAST_INSERT_ID() as last_id"));
		} else {
			$seqs = $item_seqs;
		}
		$trade_mem_id = $wpdb->get_var($wpdb->prepare("
			SELECT mem_id FROM ekptgf_trade_item WHERE seq_no = %d"
			, $trade_seq_no));
		// 交換申込TBLへ挿入
		$query = $wpdb->prepare("
			INSERT INTO ekptgf_trade_apply
				(trade_item_seq_no, trade_item_mem_id, mem_id, trade_comment, status, created)
			VALUES (%d, %d, %d, %s, %s, now())", $trade_seq_no, $trade_mem_id, $mem_id, $comment, $status);
		$res = $wpdb->query($query);
		$last_id = $wpdb->get_var($wpdb->prepare("SELECT LAST_INSERT_ID() as last_id"));
		$status = 'A';
		foreach ($seqs as $seq) {
			// 交換申込明細TBLへ挿入
			$query = $wpdb->prepare("
				INSERT INTO ekptgf_trade_apply_det
					(trade_apply_seq_no, mem_item_own_seq_no, created)
				VALUES (%d, %d, now())", $last_id, $seq);
			$res = $wpdb->query($query);
			// 所有アイテムのステータスを変更
			$query = $wpdb->prepare("
				UPDATE ekptgf_mem_item_own SET status = %s WHERE seq_no = %d
				", $status, $seq);
			$res = $wpdb->query($query);
		}
		// 挿入処理後の会員の交換申込一覧を取得
		$items = array();
		if ($res) {
			$items = $this->get_apply_item_list_by_seqno($last_id);
		} else {
			$json_api->error('insert is failed.');
		}
		return $items;

	}
	/**
