	public function get_memitemboxowns($mem_id = 0, $item_type = 1, $item_cate = 1, $offset = 0, $limit = 5) {
		global $wpdb;
		global $json_api;

		if ($item_type == 'ベース') {

			$query = "SELECT mio.* , mi.type_label, mi.category_label, mi.style_label, mi.rare_label, mi.color_label, mi.item_title, mi.image_url01
				FROM ekptgf_mem_item_own mio 
	        	INNER JOIN ekptgf_m_item mi ON mio.item_id = mi.item_id
				WHERE mem_id = %d
				AND mi.type_label = %s
				AND mi.category_label = %s
				AND mio.status in ('E','U')
				ORDER BY seq_no
				LIMIT %d, %d";

			$wp_memitemboxowns = $wpdb->get_results($wpdb->prepare(
				$query, $mem_id, $item_type, $item_cate, $offset, $limit));

		} else {

			$query = "SELECT mio.* , mi.type_label, mi.category_label, mi.style_label, mi.rare_label, mi.color_label, mi.item_title, mi.image_url01, COUNT(mio.item_id) item_num
		        FROM ekptgf_mem_item_own mio 
		        INNER JOIN ekptgf_m_item mi ON mio.item_id = mi.item_id
				WHERE mem_id = %d
				AND mi.type_label = %s
				AND mio.status in ('E','U')
				GROUP BY mio.item_id
				LIMIT %d, %d";

			$wp_memitemboxowns = $wpdb->get_results($wpdb->prepare(
				$query, $mem_id, $item_type, $offset, $limit));
		}

		$items = array();
		foreach ($wp_memitemboxowns as $itembox) {
			$items[] = new JSON_API_Ekptgfmemitemown($itembox);
		}

		return $items;
		
	}

	// 画面：交換所ホーム　から呼び出される。
	public function get_memtrade_itembox($mem_id = 0, $trade_type, $category_label, $offset, $limit) {
		global $wpdb;
		global $json_api;
		$trade_type     = isset($trade_type) ? $trade_type : 'market' ;
		$category_label = isset($category_label) ? $category_label : 'ヘッド' ;
		$offset         = isset($offset) ? $offset : 0 ;
		$limit          = isset($limit) ? $limit : 5 ;
		if ($trade_type == 'market') {
			// 自分以外の出品リスト
			$query = "SELECT SQL_CALC_FOUND_ROWS ti.*
				FROM ekptgf_trade_item           AS ti
				INNER JOIN ekptgf_trade_item_det AS tid ON ti.seq_no = tid.trade_item_seq_no
				INNER JOIN ekptgf_mem_item_own   AS mio ON tid.mem_item_own_seq_no = mio.seq_no
				INNER JOIN ekptgf_m_item         AS mi  ON mio.item_id = mi.item_id
				WHERE ti.mem_id <> %d
				AND ti.status = 'S'
				AND mi.category_label = %s
				ORDER BY seq_no asc
				LIMIT %d, %d";
			$wp_memtradeitems = $wpdb->get_results($wpdb->prepare(
				$query, $mem_id, $category_label, $offset, $limit));
		} else {
			// 自分の出品リスト
			$query = "SELECT SQL_CALC_FOUND_ROWS *
		        FROM ekptgf_trade_item  ti 
				WHERE mem_id = %d
				AND ti.status = 'S'
				ORDER BY seq_no asc
				LIMIT %d, %d";
			$wp_memtradeitems = $wpdb->get_results($wpdb->prepare(
				$query, $mem_id, $offset, $limit));
		}
        $allcount = $wpdb->get_var($wpdb->prepare("SELECT FOUND_ROWS() as `allcnt`;"));
		$items = array();
		foreach ($wp_memtradeitems as $wp_memtradeitem) {
			$items[] = new JSON_API_Ekptgftradeitem($wp_memtradeitem);
		}
        $retvar = array( "allcount"=>$allcount, "items"=>$items );
		return $retvar;
	}
		
	public function exec_memgacyas($seq_nos = array()) {
		global $wpdb;
		global $json_api ;
		$item_id_by_draw = 0;
		$num_of_item = 0;
		
		if (isset($seq_nos)) {
			// 使用可能なガチャのみ取得
			$query_param = str_replace(',', ' OR seq_no = ', $seq_nos);
			$query = "SELECT * FROM ekptgf_mem_gacya WHERE status = 'U' AND seq_no =";
			$query .= $wpdb->escape($query_param);
			$enabled_gacyas = $wpdb->get_results($query);
		} else {
			$enabled_gacyas = $seq_nos;
		}
		if (!count($enabled_gacyas)) {
			$json_api->error("Error gacya status is invalid. Check params in seq_nos =".$seq_nos);
		}
		// ガチャによりアイテムを取得
		$wp_gacyas = array();
		foreach ($enabled_gacyas as $gacya) {
			$wp_gacyas[] = $this->exec_memgacya($gacya->seq_no);
		}

		return $wp_gacyas;

	}

