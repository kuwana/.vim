	public function get_reply_trade_list($reply_seq_nos = '') {
		global $wpdb;
		global $json_api;

		if (empty($reply_seq_nos)) { // seq_noの指定が存在しない場合
			$seqs = array();
		} else { // seq_noの指定が存在する場合
			$seqs = explode(',', $reply_seq_nos);
		}

		foreach ($seqs as $seq) {
		$wp_replytrades = $wpdb->get_results($wpdb->prepare("
			SELECT ti.*, tid.mem_item_own_seq_no, ta.mem_id, ta.trade_comment, tad.mem_item_own_seq_no
			FROM ekptgf_trade_item ti
				INNER JOIN ekptgf_trade_item_det tid
				ON ti.seq_no = tid.trade_item_seq_no
				INNER JOIN ekptgf_trade_apply ta
				ON ti.seq_no = ta.trade_item_seq_no
				INNER JOIN ekptgf_trade_apply_det tad
				ON ta.seq_no = tad.trade_apply_seq_no
			WHERE ti.seq_no = %d
			", $seq));
		}
		foreach ($wp_replytrades as $wp_replytrade) {
			$items[] = new JSON_API_Ekptgftradedetail($wp_replytrade);
		}

		return $items;
	}

