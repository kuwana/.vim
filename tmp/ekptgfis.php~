	/**
	 * トレードの実行
	 */
	public function exec_trade_item( $trade_item_seq_no, $apply_item_seq_no) {

		global $wpdb;
		global $json_api;

		$items = array();
		// ------------------------------------
		// trade_itemのseq_noを元に、
		// 交換を行う所有アイテムのseq_noを取得
		// ------------------------------------
		// 出品アイテムのseq_noを取得
		$send_own_seq_nos = $wpdb->get_col($wpdb->prepare("
			SELECT tid.mem_item_own_seq_no
			FROM ekptgf_trade_item ti
			INNER JOIN ekptgf_trade_item_det tid
			ON ti.seq_no = tid.trade_item_seq_no
			WHERE ti.seq_no = %d
			", $trade_item_seq_no));
		if ( !$send_own_seq_nos) {
			$json_api->error("exec_trade_item - get trade items error.");
		}
		// 申請アイテムのseq_noを取得
		$apply_own_seq_nos = $wpdb->get_col($wpdb->prepare("
			SELECT tad.mem_item_own_seq_no
			FROM ekptgf_trade_apply ta
			INNER JOIN ekptgf_trade_apply_det tad
			ON ta.seq_no = tad.trade_apply_seq_no
			WHERE ta.seq_no = %d
		", $apply_item_seq_no));
		if ( !$apply_own_seq_nos) {
			$json_api->error("exec_trade_item - get apply items error.");
		}
		
		// ------------------------------
		// 両者の所有アイテムの交換を行う
		// ------------------------------
		// 申請アイテムの所有者IDとマスターアイテムIDを取得
		$query = 'SELECT * FROM ekptgf_mem_item_own';
		$query .= ' WHERE seq_no IN ('. implode(',', $apply_own_seq_nos) .')';
		$apply_items = $wpdb->get_results($wpdb->prepare($query));

		// 出品アイテムの所有者IDとマスターアイテムIDを取得
		$query = 'SELECT * FROM ekptgf_mem_item_own';
		$query .= ' WHERE seq_no IN (' . implode(',', $send_own_seq_nos) .')';
		$send_items = $wpdb->get_results($wpdb->prepare($query));

		// 申請者の所有アイテムに出品アイテムを追加
		foreach ($send_items as $sitem) {
			$memitem_a = $this->add_memitemown_trade($apply_items[0]->mem_id, $sitem->seq_no, 2, $trade_item_seq_no );
		}
		if ( count($memitem_a) == 0 ) { $json_api->error("Error add_memitemown - to -."); }
		$items[] = $memitem_a;

		// 出品者の所有アイテムに申請アイテムを追加
		foreach ($apply_items as $aitem) {
			$memitem_s = $this->add_memitemown_trade($send_items[0]->mem_id, $aitem->seq_no, 1, $apply_item_seq_no );
		}
		if ( count($memitem_s) == 0 ) { $json_api->error("Error add_memitemown - from -."); }
		$items[] = $memitem_s;

		// ------------------------
		// 各ステータスの変更を行う
		// ------------------------
		// 出品完了にする
		$status = "D" ;
		$query = $wpdb->prepare("
			UPDATE ekptgf_trade_item SET status = %s, modified = now() WHERE seq_no = %d", $status, $trade_item_seq_no) ;
		$res = $wpdb->query( $query );
		if ( !$res ) { $json_api->error("Error update trade_item status."); }

		// 申請完了にする
		$status = "D" ;
		$query = $wpdb->prepare("
			UPDATE ekptgf_trade_apply SET status = %s, modified = now() WHERE seq_no = %d", $status, $apply_item_seq_no ) ;
		$res = $wpdb->query( $query );
		if ( !$res ) { $json_api->error("Error update trade_item status."); }

		// 出品者の所有アイテムを使用不可にする
		$status = "D" ;
		foreach ($send_own_seq_nos as $seq) {
			$query = $wpdb->prepare("
				UPDATE ekptgf_mem_item_own SET status = %s, modified = now() WHERE seq_no = %d"
				, $status, $seq);
			$res = $wpdb->query( $query );

			if ( !$res ) { $json_api->error("Error update apply_own_item status."); }
		}

		// 申請者の所有アイテムを使用不可にする
		$status = "D" ;
		foreach ($apply_own_seq_nos as $seq) {
			$query = $wpdb->prepare("
				UPDATE ekptgf_mem_item_own SET status = %s, modified = now() WHERE seq_no = %d"
				, $status, $seq);
			$res = $wpdb->query( $query );

			if ( !$res ) { $json_api->error("Error update apply_own_item status."); }
		}

		// 他の申請を不成立にする
		$status = "D" ;
		$query = $wpdb->prepare("
			UPDATE ekptgf_trade_apply SET status = %s, modified = now() WHERE trade_item_seq_no = %d AND seq_no <> %d"
			, $status, $trade_item_seq_no, $apply_item_seq_no) ;
		$res = $wpdb->query( $query );

		return $items;
	}

