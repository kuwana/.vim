class JidouHanbaiki{
	int money;
	JidouHanbaiki( int money ){
		this.money = money;
	}
	void hantei(){
		int amari,maisu;
		maisu = this.money / 1000;
		amari = this.money % 1000;
		System.out.println("1000円札は" + maisu + "枚");
		maisu = amari / 100;
		amari = amari % 100;
		System.out.println("100円玉は" + maisu + "枚");
		maisu = amari / 10;
		System.out.println("10円玉は" + maisu + "枚");
	}
}

