function ekpt_log_message($output, $path = null) {
    $str = date('y/m/d h:i:s') . ' ' .var_export($output, true);
    $path = isset($path) ? $path : TEMPLATEPATH . '/ekptlog.txt';
    $fp = fopen($path, 'a');
    fwrite($fp, "{$str}\n");
    fclose($fp);
    // print_r('OK!'.$path);
    // print_r($fp);
}

