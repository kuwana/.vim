// 合成時のベースアイテムの必要チケット数を求める
function ekpt_get_item_comp_ticket_count( $rare_label, $level_num ) {
   
   if ( $rare_label == 'N') {
      $ret_num = 1 ;
   } else if ( $rare_label == 'N+') {
      $ret_num = 4 ;
   } else if ( $rare_label == 'R') {
      $ret_num = 6 ;      
   } else if ( $rare_label == 'R+') {
      $ret_num = 8 ;
   } else if ( $rare_label == 'SR') {
      $ret_num = 12 ;
   } else if ( $rare_label == 'SR+') {
      $ret_num = 16 ;
   } else {
      trigger_error('ekpt_get_item_comp_ticket_count:Invalid product_info = '. $rare_label, E_USER_ERROR);
   }
   $ret_num = $ret_num * $level_num ;
   return $ret_num;
}


