// 設定 稼働時には適切なものにする必要があります。
function ekpt_get_opt( $optLabel ) {
    $optValue = '' ;
    if ( $optLabel == 'EKPTHOME' ) {
        $optValue = EKPTDEF_HOME ;
    } elseif ( $optLabel == 'EKPTHOMEAPICHECKTOKEN' ) {
        $optValue = EKPTDEF_HOMEAPICHECKTOKEN ;
    } elseif ( $optLabel == 'EKPTGFHOME' ) {
        $optValue = home_url(EKPTDEF_GFHOME) ;
    } elseif ( $optLabel == 'EKPTAPI') {
        $optValue = home_url(EKPTDEF_API) ;
    } elseif ( $optLabel == 'EKPTAPITRADE') {
        $optValue = home_url(EKPTDEF_TRADEAPI) ;
    } elseif ( $optLabel == 'EKPTGFAPI') {
        $optValue = EKPTDEF_GFAPI;
    } elseif ( $optLabel == 'EKPTUSER') {
        get_currentuserinfo() ;
        $optValue = $GLOBALS['ekpt_mem_id'] ;
        if ( $optValue == '' ) {
            $optValue = EKPTDEF_USER;
        }
    }
	// echo '<br>' . $optLabel . '=' . $optValue ;
    return $optValue ;
}

