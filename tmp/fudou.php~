function ekpt_canonical() {
	if (!is_singular()) {
		return;
	}
	global $wp_the_query, $wpdb;
	if ( !$id = $wp_the_query->get_queried_object_id() )
		return;

	if (is_home()) {
		$link = get_permalink( $id );
	} else {
		$alias = $wpdb->get_var("SELECT post_name FROM $wpdb->posts WHERE ID = $id");
		$link = get_bloginfo('url').'/'.$alias.'.html';
	}

	if ( $page = get_query_var('cpage') )
		$link = get_comments_pagenum_link( $page );

	echo "<link rel='canonical' href='$link' />\n";
}
add_action('wp_head', 'ekpt_canonical');

function ekpt_rel_link() {
	if (!is_single()) {
		$fulluri = $_SERVER['HTTP_HOST'].$_SERVER['REQUEST_URI'];
		$uri = parse_url($fulluri);
		parse_str(parse_url($fulluri, PHP_URL_QUERY), $qry);
		$ctype = isset($qry['ctype']) ? '&ctype='.$qry['ctype'] : '';
		if (isset($qry['page']) && $qry['page'] != '1') {
			$prev_p = 'page='.strval($qry['page'] - 1);
			$prev_offset = '&offset='.strval($qry['offset'] - 9);

			echo '<link rel="prev" href="'.$uri['path'].'?'.$prev_p.$ctype.$prev_offset.'" />';
		}
		if (isset($qry['page'])) {
			$next_p = 'page='.strval($qry['page'] + 1);
			$next_offset = '&offset='.strval($qry['offset'] + 9);

			echo '<link rel="next" href="'.$uri['path'].'?'.$next_p.$ctype.$next_offset.'" />';
		}
	}
}
add_action('wp_head', 'ekpt_rel_link');


