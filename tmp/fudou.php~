// 加盟店検索のフリガナを対象に含める
function ekp_search_where($where) {
	global $wpdb, $wp_the_query;
	if (!is_admin() && $wp_the_query->is_main_query() && $wp_the_query->is_search()) {
		$qstr = isset($_GET['s']) ? esc_sql(esc_attr(stripslashes($_GET['s']))) : '';
		$qstr = str_replace('&#039;', '', $qstr);
		if ($qstr != '') {
			$q1 = $wpdb->prepare("SELECT DISTINCT post_id FROM $wpdb->postmeta WHERE meta_key = 'kakakushikibiki' AND meta_value LIKE %s", '%'.$qstr.'%');
			$where .= " OR $wpdb->posts.ID IN ($q1) AND post_status = 'publish'";
		}
	} else if (is_admin()) {
		$qstr = isset($_GET['s']) ? $_GET['s'] : '';
		$qstr = str_replace('&#039;', '', $qstr);
		if ($qstr != '') {
			$q1 = $wpdb->prepare("SELECT DISTINCT post_id FROM $wpdb->postmeta WHERE meta_key = 'kakakushikibiki' AND meta_value LIKE %s", '%'.$qstr.'%');
			$where .= " OR $wpdb->posts.ID IN ($q1)";
			$where .= " OR $wpdb->posts.post_title LIKE '%$qstr%'";
		}
	}
	return $where;
}
add_filter('posts_where', 'ekp_search_where');


// 空文字検索でもsearch.phpのテンプレート使うようにする
