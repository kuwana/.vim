		global $wpdb;
		global $json_api;

		if (isset($tradebox_seq_nos)) {
			// キャンセル可能かチェックし、可能な番号のみ取得する
			$query_param = str_replace(',', ' OR seq_no = ', $tradebox_seq_nos);
			$query = "SELECT seq_no FROM ekptgf_tradebox_item WHERE status = 'U' AND seq_no =";
			$query .= $wpdb->escape($query_param);
			$enabled_cancel_nos = $wpdb->get_col($query);
		} else {
			$enabled_cancel_nos = $item_seq_nos;
		}
		$mem_id = $wpdb->get_var($wpdb->prepare("
			SELECT from_mem_id FROM ekptgf_tradebox_item WHERE seq_no = %d"
			, $enabled_cancel_nos[0]));

		// 出品を取り下げる
		$status = 'C';  // ステータス：キャンセル
		foreach ($enabled_cancel_nos as $cancel_no) {
			// 出品TBLの更新
			$query = $wpdb->prepare("
				UPDATE ekptgf_tradebox_item SET status = %s WHERE seq_no = %s
