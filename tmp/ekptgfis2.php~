		$new_base_item->item_level = $item_detail->item_level ;
		$new_base_item->up_power = $item_detail->up_power ;
		// 次のデータ
		$comp_item_index++ ;
		if ( $debug_flag ) { echo '<br>強化剤.Step22'; }
		if ( $debug_flag ) { print_r($new_base_item) ; }
	}
	// リターン
	return $new_base_item ;
  }

