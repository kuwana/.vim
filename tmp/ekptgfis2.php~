	public function exec_memgacyas($seq_nos = array()) {

		global $wpdb;
		global $json_api ;
		$item_id_by_draw = 0;
		$num_of_item = 0;
		if (isset($seq_nos)) {
			// 使用可能なガチャのみ取得
			$query_param = str_replace(',', ' OR seq_no = ', $seq_nos);
			$query = "SELECT * FROM ekptgf_mem_gacya WHERE status = 'U' AND seq_no =";
			$query .= $wpdb->escape($query_param);
			$enabled_gacyas = $wpdb->get_results($query);
		} else {
			$enabled_gacyas = $seq_nos;
		}
		if (!count($enabled_gacyas)) {
			$json_api->error("Error gacya status is invalid. Check params in seq_nos =".$seq_nos);
		}
		// ガチャによりアイテムを取得
		$wp_gacyas = array();
		foreach ($enabled_gacyas as $gacya) {
			$wp_gacyas[] = $this->exec_memgacya($gacya->seq_no);
		}
		return $wp_gacyas;
        
	}
	/* ベースアイテム変更処理 */
	public function exec_changebaseitem( $mem_id, $new_seq_no, $current_seq_no ) {
		global $wpdb;
		global $json_api;
        //
        $base_item = $wpdb->get_row($wpdb->prepare("SELECT * from ekptgf_mem_item_own where seq_no = %d", $current_seq_no));
        $merit_id = $base_item->merit_id ;
		// 現在のベースアイテムを元に戻す
		$beforestatus = 'B';
		$afterstatus = 'O';
		if ( $current_seq_no <> 0 ) {
			$query1 = $wpdb->prepare("
				UPDATE ekptgf_mem_item_own
                SET comp_status = %s, modified = now() 
				WHERE mem_id = %d
                AND merit_id = %d
                AND comp_status = %s", $afterstatus, $mem_id, $merit_id, $beforestatus);
			$res1 = $wpdb->query( $query1 );
			if ( $res1 == -1 ) {
				$json_api->error("Error update current base item status. seq_no=".$current_seq_no);
			}
		}
		// ベースアイテムを設定
		$status = 'B';
		$query2 = $wpdb->prepare("
			UPDATE ekptgf_mem_item_own 
            SET comp_status = %s, modified = now() 
			WHERE seq_no = %d", $status, $new_seq_no);
		$res2 = $wpdb->query( $query2 );
		if ( $res2 == -1 ) {
			$json_api->error("Error update new base item status. seq_no=".$new_seq_no);
		}
		$items = $this->get_membaseitem($mem_id);
		return $items;
	}

