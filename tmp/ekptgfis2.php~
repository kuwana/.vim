      if ( $base_item->item_ip >= $base_item_info->max_ip ) {
         $json_api->error("このｱｲﾃﾑはﾚﾍﾞﾙMAXです。これ以上強化剤合成できません。" );
         return null ;           
     }
	if ( $base_item->item_level >= $base_item_info->max_level ) {
		// MAXレベルに到達
		// 残りのIPを求める
		$add_ip_base = $base_item_info->max_ip - $base_item->item_ip ;
	} else {
