	        }
	        $items[] = $memitems[0] ;
		}
    }

    //　経験値回数増加データ を使用済みに設定する。
	foreach ( $upd_expoint_add as $upd_expoint ) {
		// 引き当てたオブジェクトを更新
	    $query = $wpdb->prepare("
	      UPDATE ekptgf_mem_expoint_add
	      SET status = %s,
		      up_point_u = %d,
		      up_point_zan = %d,
	          mem_expoint_limit_seq_no = 1,
	          modified = now()
	      WHERE seq_no = %d
