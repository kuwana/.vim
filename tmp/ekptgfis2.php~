	// ほしいものリスト作成
	public function make_want_list($mem_id = 0, $item_id_csv = '', $comment = '') {

		global $wpdb;

		$status = 'U';
		$res = $wpdb->get_row($wpdb->prepare("
			SELECT count(seq_no) AS cnt FROM ekptgf_mem_item_want WHERE mem_id = %d AND status = %s", $mem_id, $status));

		if ($res->cnt > 0) {
			// 全て削除
			$res = $wpdb->query($wpdb->prepare("
				UPDATE ekptgf_mem_item_want SET status = %s, modified = now() WHERE mem_id = %d", 'D', $mem_id));
		}

		$item_ids = explode(',', $item_id_csv);

		if (count($item_ids) > 5) {
			return 'ほしいものリストの上限は５個までです。';
		} else {
			foreach ($item_ids as $item_id) {
				$res = $wpdb->query($wpdb->prepare("
					INSERT INTO ekptgf_mem_item_want (mem_id, item_id, created, modified, comment, status)
					VALUES (%d, %d, now(), now(), %s, %s)", $mem_id, $item_id, $comment, $status ));
			}
		}

		return $res;
	}
