	/**
	 * 交換BOXに交換申込を行う
	 */
	public function apply_tradebox_item($trade_seq_no = 0, $item_seqs = array(), $cmt = '') {

		global $wpdb;
		global $json_api;

		$status = 'U';  // ステータス：申込中
		if (isset($item_seqs)) {
			$seqs = explode(',', $item_seqs);
		} else {
			$seqs = $item_seqs;
		}
		$mem_id = $wpdb->get_var($wpdb->prepare("
			SELECT mem_id FROM ekptgf_mem_item_own WHERE seq_no = %d"
			, $seqs[0]));
		$trade_mem_id = $wpdb->get_var($wpdb->prepare("
			SELECT from_mem_id FROM ekptgf_tradebox_item WHERE seq_no = %d"
			, $trade_seq_no));

		// 交換BOX交換申込TBLへ挿入
		$query = $wpdb->prepare("
			INSERT INTO ekptgf_tradebox_apply
				(tradebox_item_seq_no, tradebox_item_from_mem_id, mem_id, tradebox_comment, status, created)
			VALUES (%d, %d, %d, %s, %s, now())", $trade_seq_no, $trade_mem_id, $mem_id, $cmt, $status);
		$res = $wpdb->query($query);

		// 交換BOX交換申込明細TBLへ挿入
		$last_id = $wpdb->get_var($wpdb->prepare("SELECT LAST_INSERT_ID() as last_id"));
		foreach ($seqs as $seq) {
			$query = $wpdb->prepare("
				INSERT INTO ekptgf_tradebox_apply_det
					(tradebox_apply_seq_no, mem_item_own_seq_no, created)
				VALUES (%d, %d, now())", $last_id, $seq);
			$res = $wpdb->query($query);
		}

		// 挿入処理後の会員の交換BOX交換申込一覧を取得
		$items = array();
		if ($res) {
			$items = $this->get_apply_tradebox_list($mem_id);
		} else {
			$json_api->error('insert is failed.');
		}

		return $items;

	}
