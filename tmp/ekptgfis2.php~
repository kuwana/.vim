    if ( $base_infos == -1 ) {
       $json_api->error("指定された会員IDではガチャチケを所有していません。".$base_info->status);
    }
    if ( count($base_infos) < $needgacyaticketall ) {
       $json_api->error("ガチャチケが足りません。所持数/必要数=".count($base_infos)."/".$needgacyaticketall);       
    }  
    // 実際にガチャを引く処理を開始
    $retitems = array() ;
    for ( $i = 0 ; $i < $numofgacya ; $i++ ) {
         // 先頭のseq_no　のもののみ処理
         // echo 'go' ;
         $base_info_index = $i * $needgacyaticket ;
         $base_info = $base_infos[$base_info_index];
         // print_r($base_info) ;
         $items = $this->exec_memgacya($base_info->seq_no) ;
         // print_r($items) ;
         if ( count($items) > 0 ) {
            foreach ( $items as $item ) {
              $retitems[] = $item ;
            }
         }
         for ( $j = 0 ; $j < $needgacyaticketaddon ; $j++ ) { //  
           //　後に続く必要数分のgacya を使用済みに設定する。
           $indexaddon = ( $i * $needgacyaticket ) + $j + 1 ;
           $base_info = $base_infos[$indexaddon];
           $seq_no_addon = $base_info->seq_no ;
           $status = "E" ;
           $query = $wpdb->prepare("
             UPDATE ekptgf_mem_gacya
             SET status = %s,
                 modified = now()
             WHERE seq_no = %d
             ", $status, $seq_no_addon ) ;
           $res = $wpdb->query( $query );
           // print_r($res);
           if ( !$res ) {
               $json_api->error("System Errorが発生しました。");
           }
         }
    }
    // 処理終了
    return $retitems ;
  }
  
