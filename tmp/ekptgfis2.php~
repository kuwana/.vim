            if ( $cidlist_arr[$i] <= $activity_category_id_max ) {
               // アクティビティの回数制限のみ設定
               if ( $new_set > $defalut_max ) {
                    $json_api->error("アクティビティの最高数は、" . $defalut_max . "回です。現在/追加" . $current_set . '/' . $new_set) ;
               }               
            }
        }       
    }    
    // 制御データを追加
	$upd_items = array() ;
	$num_of_item = count($cidlist_arr) ;
    for ( $i = 0; $i < $num_of_item; $i++ ) {
		// カテゴリー毎に設定
		if ( $uppointlist_arr[$i] <> 0 ) { 
            //
			$upd_items[] = array( 'mem_id' => $mem_id, 'category_id' => $cidlist_arr[$i], 'category_label' => $clabellist_arr[$i], 'expoint_limit' => $uppointlist_arr[$i]) ;
	        $memitems = $this->add_memexpointlimit( $mem_id, $cidlist_arr[$i], $clabellist_arr[$i], $uppointlist_arr[$i] );
	        if ( count($memitems) == 0 ) {
