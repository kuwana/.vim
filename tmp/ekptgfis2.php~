	$debug_flag = false;
	// 合計値取得
	if ( $debug_flag ) { echo '<br>Start 1 update_memcurrent_by_merit_id merit_id='.$merit_id ; }
	$base_item = $wpdb->get_row($wpdb->prepare("
		SELECT merit_id, count(*) cou, sum(up_power) up_power, sum(up_multi) up_multi 
		from ekptgf_mem_item_equip 
		where mem_id = %d
		  and merit_id = %d
		  and status ='U'
		group by merit_id", $mem_id, $merit_id));
	if ( $debug_flag ) { echo '<br>Start 2 update_memcurrent_by_merit_id merit_id='.$merit_id ; }
	// カラム名決定
	$colname1 = $colname2 = "" ;
	if ( $merit_id == 1 ) {
		$colname1 = "current_expoint_power";
		$colname2 = "current_expoint_multi";
	} elseif ( $merit_id == 2 ) {
		$colname1 = "current_gacya_get_power";
		$colname2 = "current_gacya_get_multi";
	} elseif ( $merit_id == 3 ) {
		$colname1 = "current_ticket_get_power";
		$colname2 = "current_ticket_get_multi";
	} else {
		$json_api->error("update_memcurrent_by_merit_id Error merit_id ". $merit_id ." is invalid.");
	}
	// データ更新
    $query = $wpdb->prepare("
	  UPDATE ekptgf_mem_current
	  SET 	".$colname1." = %d,
			".$colname2." = %d,
	      modified = now()
	  WHERE mem_id = %d",
	  $base_item->up_power,
	  $base_item->up_multi,
	  $mem_id ) ;
	if ( $debug_flag ) { echo '<br>Start 3 update_memcurrent_by_merit_id merit_id='.$merit_id ; }
	if ( $debug_flag ) { print_r($query); }
	$res = $wpdb->query( $query );
    return $res;
  }

