		$comp_item_info =  $comp_item_infos[$comp_item_index] ;
		// 差を基準に%でIPを獲得する
		$add_ip = floor( $add_ip_base * ( $comp_item_info->up_multi / 100) ) ;
		// IPを設定
		// 最大値チェック
		$base_cur_ip = $base_item->item_ip ;
		$new_cur_ip = $base_cur_ip + $add_ip ;
		// IPが超える場合には、上限を設定
		if (  $new_cur_ip >= $base_item_info->max_ip ) {
			$new_cur_ip = $base_item_info->max_ip ;
			$add_ip = $new_cur_ip - $base_cur_ip ;
		}			
