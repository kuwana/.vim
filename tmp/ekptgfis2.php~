	/**
	 * 交換申込を行う
	 */
	public function apply_trade_item($trade_seq_no = 0, $item_seqs = array(), $comment = '') {

		global $wpdb;
		global $json_api;

		$status = 'U';  // ステータス：申込中
		if (isset($item_seqs)) {
			$seqs = explode(',', $item_seqs);
			$mem_id = $wpdb->get_var($wpdb->prepare("
				SELECT mem_id FROM ekptgf_mem_item_own WHERE seq_no = %d"
				, $seqs[0]));
		} else {
			$seqs = $item_seqs;
		}
		$trade_mem_id = $wpdb->get_var($wpdb->prepare("
			SELECT mem_id FROM ekptgf_trade_item WHERE seq_no = %d"
			, $trade_seq_no));

		// 交換申込TBLへ挿入
		$query = $wpdb->prepare("
			INSERT INTO ekptgf_trade_apply
				(trade_item_seq_no, trade_item_mem_id, mem_id, trade_comment, status, created)
			VALUES (%d, %d, %d, %s, %s, now())", $trade_seq_no, $trade_mem_id, $mem_id, $comment, $status);
		$res = $wpdb->query($query);

		// 交換申込明細TBLへ挿入
		$last_id = $wpdb->get_var($wpdb->prepare("SELECT LAST_INSERT_ID() as last_id"));
		foreach ($seqs as $seq) {
			$query = $wpdb->prepare("
				INSERT INTO ekptgf_trade_apply_det
					(trade_apply_seq_no, mem_item_own_seq_no, created)
				VALUES (%d, %d, now())", $last_id, $seq);
			$res = $wpdb->query($query);
		}

		// 挿入処理後の会員の交換申込一覧を取得
		$items = array();
		if ($res) {
			$items = $this->get_mem_apply_trade_list($mem_id);
		} else {
			$json_api->error('insert is failed.');
		}

		return $items;

	}
	/**
	 * 交換所の交換申込を断る
	 */
	public function reply_trade_apply($seq_no, $reply) {

		global $wpdb;

		if ($reply == 'no') {
			$status = 'C';
			$query = $wpdb->prepare("
				UPDATE ekptgf_trade_apply SET status = %s WHERE seq_no = %d", $status, $seq_no);
			$res = $wpdb->query( $query );
			if ( !$res ) {
				$json_api->error("Error update trade_apply status.");
			}
			$sender_item = $wpdb->get_row($wpdb->prepare("
				SELECT * FROM ekptgf_trade_apply WHERE seq_no = %d
				", $seq_no));
		}
		$items = array();
		$items[] = $this->get_mem_trade_item_list($sender_item->mem_id);

		return $items;
	}

