	/**
	 * 出品を取り下げる
	 */
	public function cancel_trade_item($trade_seqs = array(), $comment = '') {

		global $wpdb;
		global $json_api;

		if (isset($trade_seqs)) {
			// キャンセル可能かチェックし、可能な番号のみ取得する
			$query_param = str_replace(',', ' or seq_no = ', $trade_seqs);
			$query = "select seq_no from ekptgf_trade_item where status = 'u' and seq_no =";
			$query .= $wpdb->escape($query_param);
			$enabled_cancel_nos = $wpdb->get_col($query);
			$mem_id = $wpdb->get_var($wpdb->prepare("
				SELECT mem_id FROM ekptgf_trade_item WHERE seq_no = %d"
				, $enabled_cancel_nos[0]));
		} else {
			$enabled_cancel_nos = $trade_seqs;
		}

		// 出品を取り下げる
		$status = 'C';  // ステータス：キャンセル
		foreach ($enabled_cancel_nos as $cancel_no) {
			// 出品TBLの更新
			$query = $wpdb->prepare("
				UPDATE ekptgf_trade_item SET status = %s WHERE seq_no = %s
				", $status, $cancel_no);
			$res1 = $wpdb->query($query);

			// 交換申込TBLの更新
			$query = $wpdb->prepare("
				UPDATE ekptgf_trade_apply SET status = %s WHERE trade_item_seq_no = %s
				", $status, $cancel_no);
			$res2 = $wpdb->query($query);
		}

		if ($res1 || $res2) {
			// キャンセル後の会員の出品一覧の取得
			$items[] = $this->get_mem_trade_item_list($mem_id);
		} else {
			$json_api->error('update is failed');
		}
		return $items;

	}

