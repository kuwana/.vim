	public function get_memitemboxowns($mem_id = 0, $item_type, $item_cate, $status, $offset, $limit ) {
		global $wpdb;
		global $json_api;
		$item_type = isset($item_type) ? $item_type : 'ベース' ;
		$item_cate = isset($item_cate) ? $item_cate : 'ボディ' ;
		$status = isset($status) ? $status : "'U'" ;
		$offset = isset($offset) ? $offset : 0 ; 
		$limit = isset($limit) ? $limit : 10 ;
		if (strlen($status) == 0) {
			$status = "'U'" ;
		}
        // echo '?';
		if ($item_type == 'ベース') {
			$query = "SELECT SQL_CALC_FOUND_ROWS mio.* , mi.type_label, mi.category_label, mi.style_label, mi.rare_label, mi.color_label, mi.item_title, mi.image_url01, mi.max_level
				FROM ekptgf_mem_item_own mio 
	        	INNER JOIN ekptgf_m_item mi ON mio.item_id = mi.item_id
				WHERE mem_id = %d
				AND mio.status in (" . $status . ")
				AND mi.type_label = %s
				AND mi.category_label = %s
				ORDER BY status desc, item_level, mi.max_level desc
				LIMIT %d, %d";
			$wp_memitemboxowns = $wpdb->get_results($wpdb->prepare(
				$query, $mem_id, $item_type, $item_cate, $offset, $limit));
			/* if ( !$wp_memitemboxowns ) {
				$errorObj = var_export($wpdb, true);
				$json_api->error("Error get_memitemboxowns.Object=" . $errorObj );
			} */
		} else {
           //  素材データを取得
			$query = "SELECT SQL_CALC_FOUND_ROWS mio.* , mi.type_label, mi.category_label, mi.style_label, mi.rare_label, mi.color_label, mi.item_title, mi.image_url01, sum(mio.num_of_item) num_of_item, min(mi.max_level)
		        FROM ekptgf_mem_item_own mio 
		        INNER JOIN ekptgf_m_item mi ON mio.item_id = mi.item_id
				WHERE mem_id = %d
				AND mio.status in (" . $status . ")
				AND mi.type_label = %s
				GROUP BY mio.item_id
				LIMIT %d, %d";
			$wp_memitemboxowns = $wpdb->get_results($wpdb->prepare(
				$query, $mem_id, $item_type, $offset, $limit));
		}
        //print_r($wpdb);
        $allcount = $wpdb->get_var($wpdb->prepare("SELECT FOUND_ROWS() as `allcnt`;"));
        // print_r($allcount);
		$items = array();
		foreach ($wp_memitemboxowns as $itembox) {
           // 一つ一つを取得する際にSEQ_NOの配列用文字列を作成する
           if ($item_type == '素材') {
               //  素材データを取得
                $query = "SELECT mio.*
                    FROM ekptgf_mem_item_own mio 
                    WHERE mem_id = %d
                    AND mio.item_id = %d
                    AND mio.status in (" . $status . ")" ;
                $wp_recordsbyitem = $wpdb->get_results($wpdb->prepare(
                    $query, $mem_id, $itembox->item_id ));
                $itembox->seq_nos_str = '' ;
                foreach ( $wp_recordsbyitem as $wp_recordbyitem ) {
                   if ( $itembox->seq_nos_str == '' ) {
                      $itembox->seq_nos_str = $wp_recordbyitem->seq_no ;
                   } else {
                      $itembox->seq_nos_str .= ','.$wp_recordbyitem->seq_no ;
                   }
                }
           }
           // 素材を設定
			$items[] = new JSON_API_Ekptgfmemitemown($itembox);
		}
        // echo $allcount ;
        $retvar = array( "allcount"=>$allcount, "items"=>$items );
		return $retvar;
