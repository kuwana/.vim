			$query = $wpdb->prepare("
				UPDATE ekptgf_tradebox_apply SET status = %s WHERE tradebox_item_seq_no = %s
				", $status, $cancel_no);
			$res2 = $wpdb->query($query);
		}

		if ($res1 || $res2) {
			// キャンセル後の会員の出品一覧の取得
			$items[] = $this->get_tradebox_item_list($mem_id);
		} else {
