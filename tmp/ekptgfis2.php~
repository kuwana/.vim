	/**
	 * アイテムを出品する
	 */
	public function send_trade_item($trade_item_seqs = array(), $title = '', $desc = '') {

		global $wpdb;
		global $json_api;

		$status = 'U';  // ステータス：出品中
		if (isset($trade_item_seqs)) { // seq_noの指定が存在する場合
			$seqs = explode(',', $trade_item_seqs);
			$mem_id = $wpdb->get_var($wpdb->prepare("SELECT mem_id FROM ekptgf_mem_item_own WHERE seq_no = %d"
				, $seqs[0]));
		} else { // seq_noの指定が存在しない場合
			$seqs = $trade_item_seqs;
		}

		foreach ($seqs as $seq) {
		// 出品TBLへ挿入
		    $query = $wpdb->prepare("
				INSERT INTO ekptgf_trade_item
					(trade_no, mem_id, status, trade_title, trade_desc, created)
				VALUES(%d, %d, %s, %s, %s, now())", $seq, $mem_id, $status, $title, $desc);
			$res = $wpdb->query( $query );

		// 出品明細TBLへ挿入
	        $last_id = $wpdb->get_var($wpdb->prepare("SELECT LAST_INSERT_ID() as last_id"));
		    $query = $wpdb->prepare("
				INSERT INTO ekptgf_trade_item_det
					(trade_item_seq_no, mem_item_own_seq_no, created)
				VALUES(%d, %d, now())", $last_id, $seq);
			$res = $wpdb->query( $query );
		}

		$items = array();
		if ($res) {
			$items = $this->get_mem_trade_item_list($mem_id);
		} else {
			$json_api->error("insert is failed.");
		}

		return $items;

	}

