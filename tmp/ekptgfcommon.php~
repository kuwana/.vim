// 内部関数：　homeitemfusion 用： http用クエリ文字列を作る
function _ekptcom_qsItemFusion( $bParams  = array() ) {
	if ( count($bParams) == 0 ) { $bParams = $GLOBALS['EKPT_PARAM_ITEMFUSION'] ; }
	$qs = '' ;
	unset($bParams['json_status']) ;
	unset($bParams['json_error']) ;
	unset($bParams['base_url']) ;
	unset($bParams['home_url']) ;
	unset($bParams['current_uri']) ;
	$qs = '?' . http_build_query($bParams) ;
	return $qs ;
}

