                 if ( $comp_type_label <> $arrdata['memitemown'][0]['category_label'] ) {
                     $comp_type_label .= $arrdata['memitemown'][0]['category_label'] ;
                 }
             }
         }
         // echo 'step1';
         $GLOBALS['EKPT_ITEM_SACRIFICE'] = $vdatas ;
         $seq_no_comp = implode(',', $seq_no_comp_arr);
         // print_r($seq_no_comp);
         $bParams['comp_seq_nos'] = $seq_no_comp ;
         $bParams['comp_seq_nos_count'] = count($seq_no_comp_arr) ;
         $GLOBALS['EKPT_PARAM_ITEMFUSION'] = $bParams ;
