function _comSetupParam() {
	// 各処理の初期化モジュールを起動
	$current_page = get_page_uri($post->ID) ;
	if ( preg_match('/homeitemfusion/', $current_page) ) {
		$msg = _ekptcom_paramItemFusion() ;
	} else if ( preg_match('/homegiftgacya/', $current_page) ) {
		$msg = _ekptcom_paramGiftGacya() ;
	} else if ( preg_match('/homeinformation/', $current_page) ) {
		$msg = _ekptcom_paramInformation() ;
	} else if ( preg_match('/homecoupon/', $current_page) ) {
		$msg = _ekptcom_paramCoupon() ;
	} else if ( preg_match('/homeranking/', $current_page) ) {
		$msg = _ekptcom_paramRanking() ;
	} else if ( preg_match('/homeexpoint/', $current_page) ) {
		$msg = _ekptcom_paramExpoint() ;
	} else if ( preg_match('/homeekupopoint/', $current_page) ) {
		$msg = _ekptcom_paramEkupopoint() ;
	} else if ( preg_match('/homeitemtradebox/', $current_page) ) {
		$msg = _ekptcom_paramItemtradebox() ;
	} else if ( preg_match('/homeitemtrade/', $current_page) ) {
		$msg = _ekptcom_paramItemtrade() ;
	} else if ( preg_match('/homegiftstock/', $current_page) ) {
		$msg = _ekptcom_paramGiftStock()  ;
	} else if ( preg_match('/homeitemequip/', $current_page) ) {
		$msg = _ekptcom_paramItemEquip()  ;
	} else if ( preg_match('/homegift/', $current_page) ) {
		$msg = _ekptcom_paramCoupon() ;

	// 新トレード分追加 by kuwana 2013-01-28
	} else if ( preg_match('/mytradehome/', $current_page) ) {
		// $msg = _ekptcom2_paramItemTrade();
		$msg = _ekptcom2_paramItemTrade();
	} else if ( preg_match('/trademarkethome/', $current_page) ) {
		// $msg = _ekptcom2_paramItemTrade();
		$msg = _ekptcom2_paramItemTrade();
	}
}

