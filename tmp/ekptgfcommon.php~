		$comp_type_label = $bParams['maintypeK'] ;
		// $needTicket = $needTicket * 3 ;
        // 必要チケット数 経験値GET力*2
        $needTicket = ekpt_get_item_comp_ticket_count($baseinfo['rare_label'] , $baseinfo['item_level'] ) ;
