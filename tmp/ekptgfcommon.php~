		$html .= '[callout style="text-align:center; color:red; text-size:120%;"]素材を、最低一つ、選んでください。[/callout]';
	}
	// 合成可能な場合ボタンを出力する
	if ( $compOk ) {
		if ( $needTicket <= $mem_info['numof_ticket'] ) {
            $bParamsComp = $bParams ;
            $bParamsComp['result_comp_type'] = $comp_type ;
            $bParamsComp['result_seq_no'] = $base_seq_no ;
            $bParamsComp['result_comp_seq_nos'] = $seq_no_comp ;
