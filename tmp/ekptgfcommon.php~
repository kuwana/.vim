function ekptcom_contents_itemequip_confirm($atts = array()) {
	//
   $bParams = $GLOBALS['EKPT_PARAM_ITEMEQUIP'] ;
	$mem_id = ekpt_get_opt('EKPTUSER');
    $baseurl = ekpt_get_opt('EKPTGFHOME'); 
	$html = '';
	$buf = '';
    $param = array( "mem_id" =>  $mem_id ) ;
	$mem_info = $GLOBALS['EKPTMEMINFO'];
    $mem_info_after_release = array();
    $mem_info_before_equip = array();
	$html = $html_sc ='' ;
	$oprText = $errMsg = '';
	$msgs = array() ;
	$backToken = $_REQUEST['token'];
	// パラメタ取得
	$fromSeqNo = $SeqNo = 0 ;
	$reqOprtype = $bParams['opr_type'];
	$reqSeqNo = $bParams['equip_seq_no'];
	$reqFromSeqNo = $bParams['release_seq_no'];
    $subtype = $bParams['subtype'];
    $errMsg = '' ;
//    print_r($mem_info) ;
//    print_r($bParams) ;
    // チェック処理
	if ( $reqOprtype == 'E' ) {
		$oprText = '装備' ;
		if ( $reqSeqNo == 0 ) {
			$errMsg .= '装備が指定されていますが、アイテムがありません。' ;
		}
		$SeqNo = $reqSeqNo ;
	} else if ( $reqOprtype == 'R' )  {
		$oprText = '外す' ;
		if ( $reqFromSeqNo == 0 ) {
			$errMsg .= '外すが指定されていますが、元のアイテムがありません。' ;
		}
		$fromSeqNo = $reqFromSeqNo ;
	} else if ( $reqOprtype == 'C' )  {
		$oprText = '入替' ;
		if ( $reqFromSeqNo == 0 ) {
			$errMsg .= '入替が指定されていますが、元のアイテムがありません。' ;
		}
		$fromSeqNo = $reqFromSeqNo ;
		$oprText = '装備' ;
		if ( $reqSeqNo == 0 ) {
			$errMsg .= '<br>入替が指定されていますが、装備アイテムがありません。' ;
		}
		$SeqNo = $reqSeqNo ;
        // 入替時のチェック
        if ( $subtype == 'head' ) {
           $cost_limit = $mem_info['equip_cost_head'];
           $cost_u = $mem_info['equip_cost_head_u'];
        } if ( $subtype == 'body' ) {
           $cost_limit = $mem_info['equip_cost_body'];
           $cost_u = $mem_info['equip_cost_body_u'];       
        } if ( $subtype == 'leg' ) {
           $cost_limit = $mem_info['equip_cost_leg'];
           $cost_u = $mem_info['equip_cost_leg_u'];       
        }
        $cost_equip = $cost_u - $bParams['release_item_cost'];
        $cost_equip = $cost_equip + $bParams['equip_item_cost'];
        if ( $cost_equip > $cost_limit ) {
           $errMsg .= '入替できません。装備コストが足りません。'.'<br>装備コストMAX '.$cost_limit.'<br>使用中コスト '.$cost_u .'<br>外すコスト '.$bParams['release_item_cost'].'<br>つけるコスト '.$bParams['equip_item_cost'].'<br>入替後コスト '.$cost_equip;
        }
	}
    // print_r($reqFromSeqNo);
	// 装備コストのチェック実施
	// 解除処理を実行
	if ( $errMsg ==  '' ) {
		if ( $fromSeqNo <> 0 ) {
			// 解除処理を実行
		    // パラメタ設定
		    $param = array( 'seq_no' =>  $fromSeqNo ) ;
		    $jsondata = ekpt_get_json('update_memitemequip', $param);
			if ($jsondata['status'] == 'error') {
				$errMsg .= $jsondata['error'] . '<br>' ;
			} else {
			    // 配列データを取得
			    $vdatasFrom = $jsondata['memitemowns'];
			}
            // 呼び出し先設定
            $param2 = array( "mem_id" =>  $mem_id ) ;
            $urldata2 = 'Mem/GetLevelExpoint' ;
            $urlbase2 = ekpt_get_opt('EKPTGFAPI') ;
            // データ取得
            $retdata2 = ekpt_get_json( $urldata2, $param2, $urlbase2);
            $mem_info_after_release = $retdata2['data'] ;
            $mem_info_before_equip = $retdata2['data'] ;
		}
		// 装備処理を実行
		if ( $SeqNo <> 0 ) {
		    // パラメタ設定
		    $param = array( "seq_no" =>  $SeqNo ) ;
		    $jsondata = ekpt_get_json('add_memitemequip', $param);
			if ($jsondata['status'] == 'error') {
				$errMsg .= $jsondata['error'] ;
			} else {
			    // 配列データを取得
			    $vdatas = $jsondata['memitemequips'];
			}
            // 呼び出し先設定
            $param2 = array( "mem_id" =>  $mem_id ) ;
            $urldata2 = 'Mem/GetLevelExpoint' ;
            $urlbase2 = ekpt_get_opt('EKPTGFAPI') ;
            // データ取得
            $retdata2 = ekpt_get_json( $urldata2, $param2, $urlbase2);
            $mem_info_after_equip = $retdata2['data'] ;            
		}
	}
	// チェック
	// メッセージ送信
    $html = '[callout align="center" text-align="center"]' ;
	if ( $errMsg <> '' ) {
		$html .= '<p style="color:red">' . $errMsg . '</red>';
	} else {
		foreach ( $vdatasFrom as $vdatafrom ) {
			$html .= $vdatafrom['item_title'] . ' を、装備から外しました。' ;
            $mem_info_old = $mem_info ;
            $mem_info_new = $mem_info_after_release ; 
