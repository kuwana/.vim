			$html .= '<br>ﾁｹｯﾄ数:'.$mem_info['numof_ticket'].'=>'.$zanTicket.'枚'.'</div>';
			// $opturlBase = ekpt_get_link_param($params);
			$html .= '[button align="center" color="lightgreen" size="large" link="'.esc_html($baseurl.$type.$func.$opturl).'"]'. $comp_type_label .' 合成を実行する[/button]';
		} else {
			$zanTicket = 0 ;
			$html .= '<div class="cta" style="text-align:center;">必要ﾁｹｯﾄ数'. $needTicket .'枚';
			$html .= '<br>ﾁｹｯﾄ数:'.$mem_info['numof_ticket'].'枚';
			$html .= '<br><span style="color:red; font-size:150%;">※ﾁｹｯﾄが足りません！</span></div>';
		}
	}
	// 戻るボタンは共通
	$html .= _ekptcom_returnItemFusion() ;
    // 出力指定
    return do_shortcode($html) ;
}
