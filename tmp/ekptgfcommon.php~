				$html .= '<br>装備コストが<br>' . $mem_info_old['equip_cost_head_u'] . '/' . $mem_info_old['equip_cost_head'] . 'から' . $mem_info_new['equip_cost_head_u'] . '/' . $mem_info_new['equip_cost_head'] . ' になりました。'  ;
			} else if ( $vdatafrom['category_label'] == 'ボディ' ) {
				$html .= '<br>ボディ力が<br>「' . strip_tags($mem_info_old['current_item_get_power_desc']) . '」から「' . strip_tags($mem_info_new['current_item_get_power_desc']) . '」 になりました。' ;
				$html .= '<br>装備コストが<br>' . $mem_info_old['equip_cost_body_u'] . '/' . $mem_info_old['equip_cost_body'] . 'から' . $mem_info_new['equip_cost_body_u'] . '/' . $mem_info_new['equip_cost_body'] . ' になりました。'  ;
			} else if ( $vdatafrom['category_label'] == 'レッグ' ) {
				$html .= '<br>レッグ力が<br>「' . strip_tags($mem_info['current_ticket_get_power_desc']) . '」から「' . strip_tags($mem_info_new['current_ticket_get_power_desc']) . '」 になりました。'  ;
				$html .= '<br>装備コストが<br>' . $mem_info_old['equip_cost_leg_u'] . '/' . $mem_info_old['equip_cost_leg'] . 'から' . $mem_info_new['equip_cost_leg_u'] . '/' . $mem_info_new['equip_cost_leg'] . ' になりました。'  ;
			}
		}
		if (count($vdatasFrom) > 0 ) {
			$html .= '<br><br>' ;
		}
		foreach ( $vdatas as $vdata ) {
            if ( count($mem_info_after_release) > 0 ) {
               $mem_info_old = $mem_info_before_equip ;
