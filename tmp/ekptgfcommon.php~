function ekptcom_change_contents_test($atts = array()) {
	$mem_id = ekpt_get_opt('EKPTUSER');
    $baseurl = ekpt_get_opt('EKPTGFHOME'); 
	$gid = isset($_REQUEST['tid']) ? $_REQUEST['tid'] : 0 ;
	$reqMaintype = $_REQUEST['maintype'];
	$reqSubttype = $_REQUEST['subtype'];
	$html = '';
	$buf = '';
    $mem_id = ekpt_get_opt("EKPTUSER") ;
    $param = array( "mem_id" =>  $mem_id ) ;
	$mem_info = $GLOBALS['EKPTMEMINFO'];
	$html = $html_sc ='' ;
	// 表示対象制御
	$mainType = 'base' ; // =base =sozai =coupon
	$subType = "head" ; // =head(default) body leg acc
	$button_color_base = $button_color_sozai = $button_color_coupon = 'red' ;
	if (strlen($reqMaintype) <> 0) {
		if ( $reqMaintype == 'base' ) {
			$mainType  = 'base' ;
			$button_color_base = 'white' ;
		} else if ( $reqMaintype == 'sozai' ) {
			$mainType = 'sozai' ;
			$button_color_sozai = 'white' ;
		} else if ( $reqMaintype == 'coupon' ) {
			$mainType = 'coupon' ;
			$button_color_coupon = 'white' ;
		} else {
			$html = 'Error: Invalid Parameter. maintype='.$reqMaintype ;
			return $html ;
		}
	} else {
		$button_color_base = 'white' ;
	}
    // テスト
    //print_r($_SERVER) ;
    
    
	$button_color_head = $button_color_body = $button_color_leg = $button_color_acc = 'green' ;
	$activeHead = $activeBody = $activeLeg = $activeAcc ;
	if (strlen($reqSubttype) <> 0) {
		if ( $reqSubttype == 'head' ) {
			$subType  = 'head' ;
			$activeHead = 'active';
			$button_color_head = 'white' ;
		} else if ( $reqSubttype == 'body' ) {
			$subType = 'body' ;
			$activeBody = 'active';
			$button_color_body = 'white' ;
		} else if ( $reqSubttype == 'leg' ) {
			$subType = 'leg' ;
			$activeLeg = 'active';
			$button_color_leg = 'white' ;
		} else if ( $reqSubttype == 'acc' ) {
			$subType = 'acc' ;
			$activeAcc = 'active';
			$button_color_acc = 'white' ;
		} else {
			$html = 'Error: Invalid Parameter. subtype='.$reqSubtype ;
			return $html ;
		}
	} else {
		$button_color_head = 'white' ;
		$activeHead = 'active';
	}
	// 表示レコード制御
	// パラメタ作成
	$params = array() ;
	$opturl = ekpt_get_link_param( $params ) ;
    // 種別切替部
	$linkPage = $baseurl . 'homeitembox/';
	$linkBase = esc_html($linkPage.$opturl.'&maintype=base&tid=0') ;
	$linkSozai = esc_html($linkPage.$opturl.'&maintype=sozai&tid=1') ;
	$linkCoupon = esc_html($linkPage.$opturl.'&maintype=coupon&tid=2') ;
    // 出力部
	$html_sc .= '<div class="hbtn">' ;
	$html_sc .= '<div class="hbtn-inner">[button align="center" color="' . $button_color_base . '" size="medium" link="'.$linkBase.'&'.'"]ﾍﾞｰｽ[/button]';
	$html_sc .= '[button align="center" color="' . $button_color_sozai . '" size="medium" link="'.$linkSozai.'"]素材[/button]';
	$html_sc .= '[button align="center" color="' . $button_color_coupon . '" size="medium" link="'.$linkCoupon.'"]ｸｰﾎﾟﾝ[/button]' ;
	$html_sc .= '<div class="clear"></div>' ;
	$html_sc .= '</div>' ;
	$html_sc .= '</div>' ;
	$html .= do_shortcode($html_sc) ;
	if ( $mainType  == 'base' ) {
    // ベースアイテム切替部
		$linkPage = $baseurl . '/homeitembox/' . $opturl . '&maintype=base&tid=0';
		$linkHead = esc_html($linkPage.'&subtype=head') ;
		$linkBody = esc_html($linkPage.'&subtype=body') ;
		$linkLeg = esc_html($linkPage.'&subtype=leg') ;
		$linkAcc = esc_html($linkPage.'&subtype=acc') ;
		/*
		$html_sc = '' ;
		$html_sc .= '<div class="hbtn">' ;
		$html_sc .= '<div class="hbtn-inner">[button align="center" color="' . $button_color_head . '" size="medium" link="'.$linkHead.'"]ﾍｯﾄﾞ[/button]';
		$html_sc .= '[button align="center" color="' . $button_color_body . '" size="medium" link="'.$linkBody.'"]ﾎﾞﾃﾞｨ[/button]';
		$html_sc .= '[button align="center" color="' . $button_color_leg . '" size="medium" link="'.$linkLeg.'"]ﾚｯｸﾞ[/button]' ;
		$html_sc .= '[button align="center" color="' . $button_color_acc . '" size="medium" link="'.$linkAcc.'"]ｱｸｾｻﾘ[/button]' ;
		$html_sc .= '<div class="clear"></div>' ;
		$html_sc .= '</div>' ;
		$html_sc .= '</div>' ;
		$html .= do_shortcode($html_sc) ;
		*/
		// 出力部
        $headnum = $mem_info['current_expoint_e']+$mem_info['current_expoint_u'];
        $bodynum = $mem_info['current_item_e']+$mem_info['current_item_u'];
        $legnum = $mem_info['current_ticket_e']+$mem_info['current_ticket_u'];
		$html .= '<div class="hbtn">' ;
		$html .= '<div class="hbtn-inner">';
		$html .= '<ul id="menuekpt">';
		$html .= '    <li class="' . $activeHead. '"><a href="' . $linkHead . '">ﾍｯﾄﾞ='.$headnum.'個</a></li>' ;
		$html .= '    <li class="' . $activeBody. '"><a href="' . $linkBody . '">ﾎﾞﾃﾞｨ='.$bodynum.'個</a></li>' ;
		$html .= '    <li class="' . $activeLeg. '"><a href="' . $linkLeg . '">ﾚｯｸﾞ='.$legnum.'個</a></li>' ;
		$html .= '    <li class="last ' . $activeAcc. '"><a href="' . $linkAcc . '">ｱｸｾｻﾘ=0個</a></li>' ;
		$html .= '</ul>' ;
		$html .= '<div class="clear"></div>' ;
		$html .= '</div>' ;
		$html .= '</div>' ;
	}
	if ($mainType == 'base') {
		if ( $subType == 'head' ) {
			$buf .= '[ekptcom_contents_item_box limit=10 tid=0 cid=0 maintype="base" subtype="head"]';
		} else if ( $subType == 'body' ) {
			$buf .= '[ekptcom_contents_item_box limit=10 tid=0 cid=1 maintype="base" subtype="body"]';
		} else if ( $subType == 'leg' ) {
			$buf .= '[ekptcom_contents_item_box limit=10 tid=0 cid=2 maintype="base" subtype="leg"]';
		} else if ( $subType == 'acc' ) {
			$buf .= '[ekptcom_contents_item_box limit=10 tid=0 cid=3 maintype="base" subtype="acc"]';
		}
		$html .= do_shortcode($buf);
		$html .= '</div>';
