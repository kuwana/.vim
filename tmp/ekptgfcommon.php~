		$html .= do_shortcode('[ekptcom_contents_item_box limit=10 tid=1 maintype="sozai" ]');
	} elseif ($mainType == 'base') {
		$html .= do_shortcode('[ekptcom_contents_item_box limit=10 tid=1 maintype="coupon" ]');
	}
	$html .= '<div class="clear"></div>' ;
	return $html;
}

