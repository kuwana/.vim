function ekptcomheadertrade($atts = array()) {

	// 引数を取り出す
	date_default_timezone_set('Asia/Tokyo');
	extract(shortcode_atts(array(
		'pagetitle' => '',
		'backpage' => '',
		'backpagetitle' => '',
	), $atts));

	// パラメタ設定
	$baseurl = ekpt_get_opt('EKPTGFHOME');
	$GLOBALS['EKPTMEMINFO'] = '' ;

	$mem_id = ekpt_get_opt("EKPTUSER") ;

	$teropText = EKPTDEF_HOMEITEM_MSG01 ;
	$optUrl = ekpt_get_link_param(array()) ;

	// 呼び出し先設定
	$param = array( "mem_id" =>  $mem_id ) ;
	$urldata = 'Mem/GetLevelExpoint' ;
	$urlbase = ekpt_get_opt('EKPTGFAPI') ;
	// データ取得
	$retdata = ekpt_get_json( $urldata, $param, $urlbase);
	$mem_info = $retdata['data'] ;
	// print_r($urlbase) ;
	// print_r($param) ;
	$GLOBALS['EKPTMEMINFO'] = $mem_info ;
	// 各処理の初期化モジュールを起動
	_comSetupParam() ;

	// return $html;
}
