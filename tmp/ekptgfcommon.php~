			if ( $status <> 'U' and $status <> 'E' ) {
                print_r($vdata) ;
				trigger_error('合成できないアイテムです。'.$vdata['seq_no'], E_USER_ERROR);
			}
			$d_vdata = ekpt_get_item_info($vdata) ;
			$desc_text = isset($d_vdata['item_desc']) ? $d_vdata['item_desc'] : '未設定' ;
            $html .= ekpt_get_item_detail_display_html($vdata, $d_vdata, $desc_text) ;
	    }
		$item_level_total = $GLOBALS['EKPTCOMPITEMLEVEL'] ;
		$item_level_total += $item_level ;
		$GLOBALS['EKPTCOMPITEMLEVEL'] = $item_level_total ;
		$html .= '[/callout]' ;
	}
	// アイテムレベルを保存
    return do_shortcode($html) ;
}

