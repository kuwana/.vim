    // print_r($bParams);
	// 素材データを取得
    // print_r($bParams);
    // print_r($_REQUEST['seq_nos']);
    if ( $bParams['call_type'] == 'base' ) {
       // 配列で取得
		$seq_nos = $_REQUEST['seq_nos'];
        $comp_seq_nos =  $bParams['comp_seq_nos'];
		$GLOBALS['EKPT_ITEM_SACRIFICE'] = array() ;
        // 先行入力分のパラメタを配列にセット
        $seq_no_comp_arr_base = array() ;
        $seq_no_comp_arr_no_check = array() ;
        $seq_no_comp_arr_from = explode(',', $comp_seq_nos);
        $seq_no_comp_arr_from_all = explode(',', $bParams['comp_seq_nos_all']);
        // print_r($seq_no_comp_arr_from) ;
        // チェックされていない値を求める
        foreach ( $seq_no_comp_arr_from_all as $seq_no_comp_from_all ) {
           if ( !in_array($seq_no_comp_from_all,$seq_nos) ) {
              $seq_no_comp_arr_no_check[] = $seq_no_comp_from_all ;
           }           
        }
        // 元からの設定値を追加
        foreach ( $seq_no_comp_arr_from as $seq_no_comp_from ) {
           if ( $seq_no_comp_from <> 0 and !in_array( $seq_no_comp_from, $seq_no_comp_arr_no_check ) ) {
              $seq_no_comp_arr_base[] = $seq_no_comp_from ;
           }
        }
        // 呼出画面の設定値を追加
        foreach ( $seq_nos as $seq_no ) {
