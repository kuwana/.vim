  public function info() {
    global $json_api;
    $php = '';
    print_r($_SERVER) ;
    if (!empty($json_api->query->controller)) {
      return $json_api->controller_info($json_api->query->controller);
    } else {
      $dir = json_api_dir();
      if (file_exists("$dir/json-api.php")) {
        $php = file_get_contents("$dir/json-api.php");
      } else {
        // Check one directory up, in case json-api.php was moved
        $dir = dirname($dir);
        if (file_exists("$dir/json-api.php")) {
          $php = file_get_contents("$dir/json-api.php");
        }
      }
      if (preg_match('/^\s*Version:\s*(.+)$/m', $php, $matches)) {
        $version = $matches[1];
      } else {
        $version = '(Unknown)';
      }
      $active_controllers = explode(',', get_option('json_api_controllers', 'ekpt'));
      $controllers = array_intersect($json_api->get_controllers(), $active_controllers);
      return array(
        'json_api_version' => $version,
        'controllers' => array_values($controllers)
      );
    }
  } 
  
	public function get_item_index() {

		global $json_api;

		extract($json_api->query->get(array('offset', 'range')));
		if (empty($offset)) {
			$posts = $json_api->introspector->get_posts(array(
			'offset' => $offset,
			'range' => $range
			));
		}
		// Use : ekptgfis2
		$items = $json_api->ekptgfis2->get_items();
		$count = count($items);
		$next = $offset + $range;
		if ($count < $next) { $next = $count - 1; }
		return array(
			'count' => $count,
			'next' => $next,
			'items' => array_slice($items, $offset, $range)
		);
	}
