/*
   * Store CSS
   *------------------------------------------------------*/

.storeContents {
  padding: 5px 0px;
}

.storeName {
  font-size:25px;
  line-height:30px;
  padding: 0.3em 0;
  vertical-align:super;
}
.storeIndex {
  padding: 5px 0;
}

/*
   * Store Tags
   *------------------------------------------------------*/
.storeIcons {
  border: dashed 1px #dcdcdc;
  width: 330px;
  float: left;
  padding: 7px;
}
.storeIcons ul {
  height: 105px;
  display: table-cell;
  vertical-align: middle;
}

.storeIcons li {
  float: left;
  display: inline;
}
.largeIcons {
  width: 135px;
  height: 105px;
  float: left;
  border-top: 2px solid #fff;
  border-right: 2px solid #fff;
}
.largeIcons li {
	width: 65px;
	height: 34px;
	padding: 8px 0;
  border-left: 2px solid #fff;
  border-bottom: 2px solid #fff;
}
.smallIcons {
  width: 190px;
  float: left;
  border-top: 2px solid #fff;
  border-right: 2px solid #fff;
}
.smallIcons li {
  width: 36px;
  height: 33px;
  line-height: 33px;
  border-left: 2px solid #fff;
  border-bottom: 2px solid #fff;
}
/*
   * Main Info
   *------------------------------------------------------*/

.mainInfo {
  float: right;
  width: 335px;
  border-top: 1px solid #dcdcdc;
  border-left: 1px solid #dcdcdc;
}

.mainInfo dt {
  float: left;
  clear: both;
  width: 70px;
  height: 40px;
  background: green;
  line-height: 40px;
  text-align: center;
  color: rgb(255,255,255);
  border-right: 1px solid #dcdcdc;
  border-bottom: 1px solid #dcdcdc;
}

.mainInfo dd {
  margin-left: 70px;
  height: 40px;
  text-align: center;
  border-right: 1px solid #dcdcdc;
  border-bottom: 1px solid #dcdcdc;
}

/*
   * SocialButton
   *------------------------------------------------------*/
.socialbtn {
	overflow: hidden;
	display: table;
	padding: 10px 0;
	width: 100%;
}

.socialbtn li {
	display: table-cell;
	height: 2em;
	line-height: 2em;
	border: 1px solid #ddd;
	border-radius: 5px;
	text-align: center;
}
.socialbtn a:hover {
	color: #aaa;
}

/*
   * Tab
   *------------------------------------------------------*/

.contentsTabHeader, .contentsTabFooter {
  clear: both;
}

.contentsTabHeader li, .contentsTabFooter li {
  display: block;
  float: left;
  width: 100px;
  height: 25px;
  line-height: 25px;
  border: 1px dashed #dcdcdc;
  text-align: center;
}

.contentsTabHeader li:hover, .contentsTab Footer li:hover {
  cursor: pointer;
}

