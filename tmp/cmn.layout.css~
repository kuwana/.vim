/* footer
------------------------------*/
#footer {
	background-color: #666;
	position: relative;
}
#footer p {
	position: absolute;
	background-color: #333333;
	font-size: 80%;
	color: #ffffff;
	padding: 5px;
	padding-left: 30px;
	top: 0;
	right: 15px;
}
#footer p a {
	color: #dddddd;
	text-decoration: none;
}

#footer address {
	padding-bottom: 1em;
	color: #fcfcfc;
	text-align: center;
	font-size: 60%;
}
.ul_queryVars02 {
	margin-bottom: 1em;
}
.ul_queryVars02 li {
	float: left;
	width: 13%;
	font-size: 84%;
	margin: 0 2%;
	color: #fcfcfc;
}
.ul_queryVars02 > li:nth-child(5) {
	padding-left: 1em;
	border-left: 1px solid #dddddd;
}
.ul_queryVars02 li dt {
	padding-left: 5%;
	margin: 0.5em 0 1em 0;
	border-left: 4px solid #ddd;
}
.ul_queryVars02 li li {
	float: none;
	width: 100%;
	font-size: 70%;
}
.ul_queryVars02 li li a,
.ul_queryVars02 li li a:visited {
	color: #ddd;
}

