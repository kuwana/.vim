/**
 * 個人のマーケット出品情報
 * added by kuwana 2013-02-09
 * 内部関数
 */
function contents_newtrade_ownlist() {

    // 属性を取り出す
    extract(shortcode_atts(array(
        'item_type' => 1,
    ), $atts));

    // 基本設定
	$bParams = $GLOBALS['EKPT_PARAM_ITEMTRADE'];
	$mem_info = $GLOBALS['EKPTMEMINFO'];
    $baseurl = ekpt_get_opt('EKPTGFHOME');
    $type = 'homeitemtrade' ; // form だからスラッシュ要らない
	$apply = '/applylist';
	$reply = '/reply';
	$done = '/done';
	$finish = '/tradeownlist';
	$html = '';

	// パラメタ設定
	$GLOBALS['EKPT_ITEM_OWNS'] = array() ;

	// 交換情報を取得
	$wqSeqnoArray = $vdatas = array() ;
	$mem_id = ekpt_get_opt("EKPTUSER") ;

	if ( $bParams['trade_item_seq_no'] == 0 ) {
		if ( $bParams['trade_item_d_seq_nos'] <> '' ) {
			// 既存指定分
			$wqSeqnoArray = explode(',',$bParams['trade_item_d_seq_nos']) ;
		} else {
			trigger_error('不正なアクセスです。', E_USER_ERROR);
		}
	} else {
		$paramList = array('seq_no' => $bParams['trade_item_seq_no']) ;
		$arrdata = ekpt_trade_get_json('get_trade_item_byseq', $paramList);
		$basedata = $arrdata['trade_item_list'];
		$d_sdatas = _contents_newsendlist_info( $basedata[0] ) ;
		$itemdetails = $arrdata['trade_item_detail_list'];
		foreach ( $itemdetails as $itemdetail ) {
			$wqSeqnoArray[] = $itemdetail['mem_item_own_seq_no'];
		}
	}
	foreach ($wqSeqnoArray as $seq_no) {
		$param2 = array( 'seq_no' => $seq_no );
		$arrdata2 = ekpt_get_json('get_memitemown_by_seqno', $param2);
		$vdatas[] = $arrdata2['memitemown'][0];
	}
	$GLOBALS['EKPT_ITEM_OWNS'] = $vdatas;
	/*
	$html .= '<div id="misc-title" class="title-bar">' . '出品情報：';
	if ( $bParams['tradetype'] == 'market' ) {
		$html .= '交換申込可能な出品です';
	} else {
		$html .= 'あなたの出品です';
	}
	 */
	// 選択したアイテム
	// 交換に関する情報
	$html_iteminfo = '<table class="table_menuList02">' ;
	foreach ($vdatas as $keys => $vdata) {
        // print_r($vdata);
        $display_vdata = ekpt_get_item_info($vdata) ;
		$html_iteminfo .= '<tr>';
		$html_iteminfo .= '<td style="vertical-align: middle;"><img src="'.$display_vdata['display_image_url01'].'" alt="'.$display_vdata['display_item_title'].'" style="height: 20%;" /></td>' ;
		if ($vdata['type_label'] == 'ベース') {
			$html_iteminfo .= ekpt_get_item_display_html2($vdata, $display_vdata);
		} else if ($mainTypeK == '素材') {
           	$html_iteminfo .= $display_vdata['display_item_title'] ;
            if ( $vdata['category_label'] == 'エクポチケット' ) {
               $html_iteminfo .= '所有個数:'.$mem_info['numof_ticket'].'枚' ;
            } else {
               $html_iteminfo .= '所有個数:'.$vdata['num_of_item'].'個';
            }
		}
		$html_iteminfo .= '</tr>';
	}
	$html_iteminfo .= '</table>';

	$html .= '<table class="tradeInfo">';
	$html .= '<tr><th>いつ？</th><td>' .$d_sdatas['created'] . '</td></tr>';
	$html .= '<tr><th>だれ？</th><td>' .$d_sdatas['mem_data']['nickname']  . '</td></tr>';
	$html .= '<tr><th>何を？</th><td>' . $html_iteminfo . '</td></tr>';
	$html .= '<tr><th>コメント</th><td>「' . $d_sdatas['trade_desc'] . '」</td></tr>';
	$html .= '</table>';

 	$qs = _ekptcom2_qshfItemTrade() ;
	if ( (int)$mem_id <> (int)$basedata[0]['mem_id']) {
		//交換申請 XXX: いらない
		$applybParams = $bParams ;
		$applybParams['recOffsetApply'] = 0 ;
		$applybParams['apply_item_seq_no'] = 0 ;
		$applybParams['apply_item_d_seq_nos'] = '' ;
		$applybParams['new_apply_item_d_seq_no'] = 0 ;
		$applybParams['del_apply_item_d_seq_no'] = 0 ;
		$qsApply = _ekptcom2_qshfItemTrade($applybParams) ;
		$html .= '<div class="hbtn"><div class="hbtn-inner">' ;

		// $html .= '[button align="center" color="lightgreen" size="large" link="'.$bParams['base_url'].$bParams['home_url'].$apply.$qsApply.'"]交換を申請します[/button]' ;
		$html .= '<div class="clear"></div>' ;
		$html .= '</div></div>' ;
	} else {
		//自分の出品
		//キャンセル申請
		$param3 = array( 'trade_seq_no' => $bParams['trade_item_seq_no'] );
		$arrdata3 = ekpt_trade_get_json('get_apply_item_list_by_trade', $param3);
		$vdatas3 = $arrdata3['apply_item_list'];
		if ( count($vdatas3) == 0 ) {
			$html .= '[callout]交換申込一覧<br>交換申込はまだありません。' ;
		} else {
			$html .= '[callout]交換申込一覧 '.count($vdatas3).'件' ;
		}
		foreach ( $vdatas3 as $vdata3 ) {
			$updbParams = $bParams ;
			$updbParams['apply_item_seq_no'] = $vdata3['seq_no'];
			$qsIn = _ekptcom2_qshfItemTrade($updbParams) ;
			$linkin = $bParams['base_url'].$bParams['home_url'].$reply.$qsIn ;
            $d_vdata3 = _contents_newapplylist_info($vdata3);
            // print_r($d_vdata3);
			$descTextApply =  $vdata3['created'] . 'に、'. $d_vdata3['mem_data']['nickname'] . ' さんから、交換申込がありました。' ;
			$html .= '<br><a href="' . $linkin . '">'.$descTextApply.'</a>' ;
		}
		$html .= '[/callout]';
		
		// 交換キャンセルボタン
		$nobParams = $bParams ;
		$nobParams['trade_apply_reply'] = 'no' ;
		$opturlNo = _ekptcom2_qshfItemTrade($nobParams) ;
	 	$html .= '<div class="hbtn"><div class="hbtn-inner">' ;
		$html .= '[button align="center" color="lightgreen" size="large" link="'.$bParams['base_url'].$bParams['home_url'].$done.$opturlNo.'"]出品をキャンセルする[/button]' ;
		$html .= '<div class="clear"></div>' ;
		$html .= '</div></div>' ;
	}
	// 戻るボタン
	// $html .= _ekptcom2_returnItemTrade();

    return do_shortcode($html) ;
}

