<?php
/**
 * aliasとpost_idを紐付けて
 * .htaccessのmod_rewriteに書き込むスクリプト
 *
 * si-media.biz用
 * @author kuwana
 */

require_once('wp-load.php');
global $wpdb;

$rules = $alias = '';
bloginfo('url');
$base = '/';  // RewriteBase(環境ごとに変えるところ)

$sql = "SELECT ID, post_name, post_type FROM $wpdb->posts WHERE post_status = 'publish' AND post_type IN ('fudo', 'page')";
$res = $wpdb->get_results($sql);

foreach($res as $key => $alias) {
	//$rules .= "RewriteCond %{REQUEST_FILENAME} !-f\n";
	//$rules .= "RewriteCond %{REQUEST_FILENAME} !-d\n";
	if($alias->post_type == 'fudo') {
		if (count($res) != $key+1) {
			$rules .= "RewriteRule ".$alias->post_name.".html/?(.*)$ ".$base."index.php?post_type=fudo&p=".$alias->ID." [QSA]\n";
		} else {
			$rules .= "RewriteRule ".$alias->post_name.".html/?(.*)$ ".$base."index.php?post_type=fudo&p=".$alias->ID." [L,QSA]\n";
		}
	} else if($alias->post_type == 'page') {
		if (count($res) != $key+1) {
			$rules .= "RewriteRule ".$alias->post_name.".html/?(.*)$ ".$base."index.php?page_id=".$alias->ID." [QSA]\n";
		} else {
			$rules .= "RewriteRule ".$alias->post_name.".html/?(.*)$ ".$base."index.php?page_id=".$alias->ID." [L,QSA]\n";
		}
	}
}
$data  = "<IfModule mod_rewrite.c>\n";
$data .= "AddType application/x-httpd-php .php .html\n";
$data .= "RewriteEngine On\n";
$data .= "RewriteBase ".$base."\n";
$data .= $rules;
$data .= 'ErrorDocument 404 '.$base.'index.php?error=404'."\n";
$data .= "</IfModule>\n";

// .htaccessに書き込む
$fp = fopen('.htaccess', 'w+');

if ($fp){
	if (flock($fp, LOCK_EX)){
		if (fwrite($fp,  $data) === FALSE){
			print("\nファイル書き込みに失敗しました\n");
		}else{
			print("\n\n" . $data."を.htaccessに書き込みました。\n");
		}
		flock($fp, LOCK_UN);
	}else{
		print("\nファイルロックに失敗しました\n");
	}
}

fclose($fp);
