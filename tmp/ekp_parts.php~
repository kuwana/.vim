/**
 * 店舗検索結果
 * arg: region(地域)
 */
function store_search_result($atts = '') {

	global $wpdb;

	// 属性を取り出す
	extract(shortcode_atts(array(
		'region' => '',
		'genre'  => '',
		'budget'  => '',
		'purpose' => '',
		'point' => ''
	), $atts));

	//SQL 条件検索
	$nowym= date('Ym');
	$meta_dat = $sql = $cls = '';
	$next_sql = true;

	$sql  = "SELECT DISTINCT(P.ID) FROM ".$wpdb->posts." AS P";

	// ポイント店舗(直リンクの為なし)
	/*
	if ( $point != '' ){
		$sql .=   " INNER JOIN " . $wpdb->postmeta . " AS PM_1 ON P.ID = PM_1.post_id";
		$cls .=   " AND PM_1.meta_key = 'tatemonomenseki' AND PM_1.meta_value = 'point'";
	}
	else {
		$sql .=   " INNER JOIN " . $wpdb->postmeta . " AS PM_1 ON P.ID = PM_1.post_id";
		$cls .=   " AND PM_1.meta_key = 'tatemonomenseki' AND PM_1.meta_value = 'coupon'";
	}
	 */
	// 予算
	if ( $budget != '' && $budget != 'none' ){
		$sql .=   " INNER JOIN " . $wpdb->postmeta . " AS PM_2 ON P.ID = PM_2.post_id";
		$cls .=   " AND PM_2.meta_key = 'kakakukoushin' AND PM_2.meta_value = '".$budget."'";
	}
	// ジャンル
	if ( $genre != '' ){
		$sql .=   " INNER JOIN " . $wpdb->postmeta . " AS PM_3 ON P.ID = PM_3.post_id";
		$cls .=   " AND PM_3.meta_key = 'madorisyurui' AND PM_3.meta_value LIKE '%".$genre."%'";
	}
	// 目的
	if ( $purpose != '' ){
		$sql .=   " INNER JOIN " . $wpdb->postmeta . " AS PM_4 ON P.ID = PM_4.post_id";
		$cls .=   " AND PM_4.meta_key = 'madorisu' AND PM_4.meta_value LIKE '%".$purpose."%'";
	}
	// エリア
	if ($region != '' && $budget != '') {
		$sql .=   " INNER JOIN " . $wpdb->term_relationships . " AS TR ON TR.object_id = P.ID";
		$sql .=   " INNER JOIN " . $wpdb->terms              . " AS T  ON TR.term_taxonomy_id = T.term_id";
		$region = explode(',', $region);
		$region2 = '';
		foreach($region as $key => $value) { // カンマ区切りを分割してシングルクォートしてまた結合
			if (count($region) != $key+1) {
			  $region2 .= "'" . $value . "',";
			} else {
				$region2 .= "'" . $value . "'"; // 最後は,付けない
			}
		}
		if ($region2 != '') {
			$cls .= " AND T.slug IN(" . $region2 . ")";
		}

	}
	$cls .= " AND P.post_status = 'publish'";
	$metas = $wpdb->get_results( $sql.' WHERE 1 '.$cls );
	$page  = get_page($_GET['page_id']);
	$page_title  = '<span>' . $page->post_title . '</span>';
	$page_parent = get_page( $page->post_parent );

	// 見出し文(SEO)
	$html = '';
	$html .= '<p class="area_description">' . $page_title . 'のエクポカードが使える店舗情報を掲載しております。';

	if ( $page_parent->post_name == 'region' || $page_parent->post_name == 'genre' ) {
		$html .= '完全個室、食べ放題あり、宴会・パーティーができる店舗を数多く掲載しております。';
	}
	if ( $page->post_name != 'all' && $page->post_name != 'others' && $page_parent->post_name != 'budget' ) {
		$html .=  $page_title . 'は多彩なシーンで活躍するグルメが魅力です。';
	}
	$html .= '</p>'; // area_description END;

	$html .= '<div id="list_simplepage">';
	$html .= '<ul class="ul_searchList01 clearfix">';
	//loop SQL
	if($metas !=''){
		//$sql2 = $wpdb->prepare($sql2,'');
		//$metas = $wpdb->get_results( $sql2, ARRAY_A );
		if(!empty($metas)) {

			//	var_dump($metas);
			foreach ( $metas as $meta ) {
				// print_r($meta);
				// $meta_id = $meta['object_id'];	//post_id

				$html .= _search_result_tpl($meta);

			}
		}else{

			$html .= "店舗がありませんでした。";

		}
	}else{
		$html .= "店舗がありませんでした。";
	}
	//loop SQL END
	$html .= '</ul><!-- ul_entryList02 -->';
	$html .= '</div><!-- list_simplepage -->';

	// 下部テキストの設置(SEO)
	$html .= '<p class="area_description">' . $page_title . 'のグルメ・クーポンは共通ポイントカードのエクポ<br><br>エクポーカードは' . $page_title . 'の飲食店(居酒屋/ダイニングバー/和食/洋食)から美容院・リラクゼーション・レジャーなどでクーポン・共通ポイントが貯まるお得なカードです。' . $page_title . 'の店舗情報を掲載しております。完全個室、食べ放題あり、宴会・パーティーができる店舗など、お客様のニーズに合った情報を提供いたします。';
	$html .= '</p>'; // area_description END;


	return $html;
}

/**
 * store_search_result内で使うテンプレート
 */
function _search_result_tpl($meta) {

	global $wpdb;

	$attachmentids = array();
	$guid_urls = array();

	$meta_id = $meta->ID;	//post_id
	$meta_data = get_post( $meta_id );
	$meta_title =  $meta_data->post_title;

	$imgdata = get_post_meta($meta_id, "fudoimg1", true);

	$sql = '';
	$sql .=  "SELECT P.ID, P.guid";
	$sql .=  " FROM $wpdb->posts as P";
	$sql .=  " WHERE P.post_type ='attachment' AND P.guid LIKE '%/$imgdata' ";
	$metas = $wpdb->get_row( $sql );

	if( !empty($metas) ){
		$attachmentids  =  $metas->ID;
		$guid_url  =  $metas->guid;
	}
	//thumbnail、medium、large、full
	$mainimg = wp_get_attachment_image_src( $attachmentids, 'medium');

	// アクセス
	$access   = get_post_meta($meta_id, 'tochisetsudomaguchi1', true);
	// ふりがな
	$ruby     = get_post_meta($meta_id, 'kakakushikibiki', true);
	// 営業時間
	$opentime = get_post_meta($meta_id, 'tatemononobeyukamenseki', true);
	// 平均予算
	$budget   = get_post_meta($meta_id, 'kakakukoushin', true);
	switch($budget) {
		case 'u1000': $budget = '1000円以下'; break;
		case 'u2000': $budget = '2000円以下'; break;
		case 'u3000': $budget = '3000円以下'; break;
		case 'u4000': $budget = '4000円以下'; break;
		case 'u5000': $budget = '5000円以下'; break;
		case 'u6000': $budget = '6000円以下'; break;
		case 'u7000': $budget = '7000円以下'; break;
		case 'u8000': $budget = '8000円以下'; break;
		case 'u9000': $budget = '9000円以下'; break;
		case 'u10000': $budget = '10000円以下'; break;
		case 'a10000': $budget = '10000円以上'; break;
	}

	//$store_url = get_bloginfo('url') . '?post_type=fudo&p=' . $meta_id;
	$store_url = get_bloginfo('url') . '/' . $meta_data->post_name . '.html';

	// レンダリング
	$html = '';
	$html .= '<li>';
	$html .= '<p class="p_searchTitle01 style_timesales">';
	$html .= '<span>グルメ</span>';
	$html .= '<p class="ruby01">' . $ruby . '</p>';
	$html .= '<h2 class="search-title">';
	$html .= '<a href="' . $store_url . '">' . $meta_title . '</a>';
	$html .= '</h2>';
	$html .= '<p id="imgmain" style="text-align: center;"><img src="' . $mainimg[0] . '"></p>';
	$html .= '</p>';
	$html .= '<ul class="ul_entryListDesc01 clearfix">';
	$html .= '<li>';
	$html .= '<h3><a href="' . $store_url . '">' . $meta_title . '</a></h3>';
	$html .= '<dl>';
	$html .= '<dt>アクセス</dt><dd>' . $access   . '</dd>';
	$html .= '<dt><br>営業時間</dt><dd>' . $opentime . '</dd>';
	$html .= '<dt><br><br>平均予算</dt><dd>' . $budget   . '</dd>';
	$html .= '</dl>';
	$html .= '</li>';
	$html .= '</ul>';
	$html .= '</li>';

	return $html;
}
/**
 * 店舗検索フォーム
 * arg: none
 */
function store_search_form() {

	// TODO: まだ動かないでござる

	global $wpdb;

	$sql = $html = '';
	$sql .= "SELECT T.term_id, T.name, T.slug, TT.parent";
	$sql .= " FROM $wpdb->terms AS T";
	$sql .= " INNER JOIN $wpdb->term_taxonomy AS TT";
	$sql .= " ON T.term_id = TT.term_id";
	$sql .= " WHERE TT.taxonomy = 'bukken'";
	$metas = $wpdb->get_results($sql, ARRAY_A);
	//$html .= '<h3>店舗選定'.$shub_txt.'</h3>';
	//$html .= 'ご希望の条件を選択して下さい(複数可)<br />';

	$site = site_url( '/' );
	$html .= '<form method="get" id="searchpage" name="searchpage" action="'.$site.'" >';
	$html .= '<input type="hidden" name="bukken" value="jsearch" >';
	$html .= '<dl>';
	$html .= '<dt>ポイント</dt>';
	$html .= '<dd><input type="checkbox" id="point" name="point" value="point"><label for="point">ポイント導入店舗</label></dd>';
	$html .= '<dt>エリア</dt>';
	$html .= '<dd><select name="region">';
	$html .= '<option value="none">こだわらない</option>';
	foreach ($metas as $v) {
		if ($v['parent'] === 0)  continue;
		$html .= '<option value="'.$v["slug"].'">'.$v["name"].'</option>'."\n";
	}
	$html .= '</select></dd>';
	$html .= '<dt>予算</dt>';
	$html .= '<dd><select name="budget">';
	$html .= '<option value="none">こだわらない</option>';
	foreach ($budget as $k => $v) {
		$html .= '<option value="'.$k.'">'.$v.'</option>'."\n";
	}
	$html .= '</select></dd>';
	$html .= '<dt>ジャンル</dt>';
	$html .= '<dd>';
	$html .= '<table>';
	$html .= '<tr>';
	$i = 1;
	foreach ($genre as $k => $v) {
		$html .= '<td><span style="display:inline-block;"><input type="checkbox" id="'.$k.'" name="genre[]" value="'.$k.'"><label for="'.$k.'">'.$v.'</label></span></td>';
		if ($i % 4 == 0) {
			$html .= '</tr><tr>';
		}
		$i++;
	}
	$html .= '</tr>';
	$html .= '</table>';
	$html .= '</dd>';
	$html .= '<dt>目的</dt>';
	$html .= '<dd>';
	$html .= '<table><tr>';
	$i = 1;
	foreach ($purpose as $k => $v) {
		$html .= '<td><span style="display:inline-block;"><input type="checkbox" id="'.$k.'" name="purpose[]" value="'.$k.'"><label for="'.$k.'">'.$v.'</label></span></td>';
		if ($i % 4 == 0) {
			$html .= '</tr><tr>';
		}
		$i++;
	}
	$html .= '</tr></table>';
	$html .= '</dd>';
	$html .= '</dl>';

	$html .= '<div class="submit" style="text-align:center;"><input type="submit" value="店舗検索" /></div>';
	$html .= '</form>';

	return $html;
}
