// 内部関数：　_ekptcom_linkCoupon 用： http用クエリ文字列を作る
function _ekptcom_linkGiftGacya( $bParams, $linktype = 'Q' ) {
	if ( count($bParams) == 0 ) { $bParams = $GLOBALS['EKPT_PARAM_GIFTGACYA'] ; }
	unset($bParams['json_status']) ;
	unset($bParams['json_error']) ;
	unset($bParams['base_url']) ;
	unset($bParams['home_url']) ;
	unset($bParams['current_uri']) ;
	$html = '' ;
	if ( $linktype == 'Q' ) {
		$html = '?' . http_build_query($bParams) ;
	} else {
		foreach ( $bParams as $vk => $vv ) {
			$html .= '<input type="hidden" name="' . $vk . '" value="' . $vv . '">';
		}
	}
	return $html ;
}

