      $html_sc .= '<br>利用ﾎﾟｲﾝﾄ数：'.$vdataCurrent['totalPointUse'] ;
      $html_sc .= '[/callout]';
      $html .= do_shortcode( $html_sc ) ; 
    }
	if ( count($vdatas) > 0 ) {
		foreach($vdatas as $vdata) {
			$point_type = '発行ﾎﾟｲﾝﾄ';
			$point_status = '正式';
			$point_label = '*** 不明 ***';
			$point_type_data = $vdata['point_type'] ;
			$point_status_data = $vdata['point_status'] ;
			if ($point_type_data == 10) {
				if ( $point_status_data == 1) {
					$point_status = '仮発行';
				} else if ( $point_status_data == 2 ) {
					$point_status = '正式発行';
				} else if ( $point_status_data == 3 ) {
					$point_status = '削除';
				} else if ( $point_status_data == 4 ) {
					$point_status = '失効';
				}
				$point_label = $point_type . '：' .$point_status ;
			} else if ($point_type_data == 20) {
				$point_label = 'キャンペーンポイント' ;
			} else if ($point_type_data == 30) {
				$point_label = '利用ﾎﾟｲﾝﾄ' ;
			} else if ($point_type_data == 40) {
				$point_label = '消滅ﾎﾟｲﾝﾄ' ;
			}
			$html .= '<ul class="item-list">' ;
			$html .= '<li class="list-three"><div class="list-three-outer" style="">' ;
			$html .= '<div class="list-three-left" style="width:18%;">' ;
			$html .= '<img style="width:50px; height:50px;" src="'.$imgurl.$image_file.'" alt="'.$image_file.'" />' ;
			$html .= '</div>' ;
			$html .= '<div class="list-three-center" style="width:47%;">' ;
			$html .= '<p style="font-size:70%;" >利用日：'.$vdata['issued_at'].'' ;
			$html .= '<br>お店の名前：'.$vdata['shop_name'].'' ;
			$html .= '<br>'.$point_label.'</p>' ;
			$html .= '</div>' ;
			$html .= '<div class="list-three-right" style="width:35%;"><ul>' ;
			if ( $vdata['amount'] <> 0 ) {
				$html .= '<li style="padding-left: 10px; font-size:80%;" >利用金額:'.$vdata['amount'].' 円</li>' ;
				$html .= '<li style="padding-left: 10px; font-size:80%;" >取得ﾎﾟｲﾝﾄ:'.$vdata['point'].' P</li>' ;
			} else {
				$html .= '<li style="padding-left: 10px; font-size:80%;" >利用ﾎﾟｲﾝﾄ:'.$vdata['point'].' P</li>' ;
			}
			$html .= '</div><div class="clear"></div>' ;
			$html .= '</div></li>' ;
			$html .= '</ul>' ;
		}
	} 
	$html .= '<div class="clear"></div>';
	//
    if ( $offset == 0 and count($vdatas) == 0 ) {
    //if ( true ) {
        //
         $html .= do_shortcode('[callout]カード利用履歴がありません。<br>右上のホームアイコンを押して、ホーム画面に戻りましょう。[/callout]') ;
       // $html .= '<div style="color:red;text-align:center;font-size:150%;">' . do_shortcode('[callout]現在こちらの画面はメンテナンス中です。<br>もう少しおまちください。[/callout]') .'</div>'  ;
	} else {
		// Pager
		$next = count($vdatas) ? $offset + $limit : 0;
		$prev = $offset > $limit ? $offset - $limit : 0;
		// previous pager
		$paramsPrev = $paramsNext = $bParams ;
		$paramsPrev['recOffset'] = $prev;
		$params = _ekptcom_linkInformation($paramsPrev) ;
		$prev_btn = do_shortcode('[button align="center" color="lightblue" size="small" link="'.esc_html($baseurl.$bParams['current_uri'].$params).'"]前へ[/button]') ;
		// next pager
		$paramsNext['recOffset'] = $next;
		$params = _ekptcom_linkInformation($paramsNext) ;
		$next_btn = do_shortcode('[button align="center" color="lightblue" size="small" link="'.esc_html($baseurl.$bParams['current_uri'].$params).'"]次へ[/button]') ;
		// ボタン設定
		$html .= '<div class="hbtn"><div class="hbtn-inner">';
		$html .= $prev_btn.$next_btn;
		$html .= '<div class="clear"></div>';
		$html .= '</div></div>';
	}
	return $html;
}

// 画面=homecoupon
function ekptcom_contents_change_coupon($atts = array()) {
	//
	$mem_id = ekpt_get_opt('EKPTUSER');
    $baseurl = ekpt_get_opt('EKPTGFHOME'); 
	$gid = isset($_REQUEST['tid']) ? $_REQUEST['tid'] : 0 ;
	$reqMaintype = $_REQUEST['maintype'];
	$html = '';
	$buf = '';
    $mem_id = ekpt_get_opt("EKPTUSER") ;
    $param = array( "mem_id" =>  $mem_id ) ;
	$mem_info = $GLOBALS['EKPTMEMINFO'];
	$html = $html_sc ='' ;
	// 表示対象制御
	$mainType = 'notuse' ; // =base =sozai =coupon
	$activeNotuse = $activeUsed = $activeOut ;
	if (strlen($reqMaintype) <> 0) {
		if ( $reqMaintype == 'notuse' ) {
			$mainType  = 'notuse' ;
			$activeNotuse = 'active';
		} else if ( $reqMaintype == 'used' ) {
			$mainType = 'used' ;
			$activeUsed = 'active';
		} else if ( $reqMaintype == 'out' ) {
			$mainType = 'out' ;
			$activeOut = 'active';
		} else {
			$html = 'Error: Invalid Parameter. maintype='.$reqMaintype ;
			return $html ;
		}
	} else {
		$mainType  = 'notuse' ;
		$activeNotuse = 'active';
	}
	// 表示レコード制御
	// パラメタ作成
	$params = array() ;
	$opturl = ekpt_get_link_param( $params ) ;
    // 種別切替部
	$linkPage = $baseurl . 'homecoupon/';
	$linkNotuse = esc_html($linkPage.$opturl.'&maintype=notuse') ;
	$linkUsed = esc_html($linkPage.$opturl.'&maintype=used') ;
	$linkOut = esc_html($linkPage.$opturl.'&maintype=out') ;
	// 出力部
	$html .= '<div class="hbtn">' ;
	$html .= '<div class="hbtn-inner">';
	$html .= '<ul id="menuekpt">';
	$html .= '    <li class="first ' . $activeNotuse. '"><a href="' . $linkNotuse . '">未使用</a></li>' ;
	$html .= '    <li class="' . $activeUsed. '"><a href="' . $linkUsed . '">使用済</a></li>' ;
	$html .= '    <li class="' . $activeOut. '"><a href="' . $linkOut . '">期限切</a></li>' ;
	$html .= '</ul>' ;
	$html .= '<div class="clear"></div>' ;
	$html .= '</div>' ;
	$html .= '</div>' ;

	if ( $mainType == 'notuse' ) {
		$buf .= '[ekptcomcontents_coupon limit=5 tid=0 maintype="notuse"]';
	} else if ( $mainType == 'used' ) {
		$buf .= '[ekptcomcontents_coupon limit=5 tid=1 maintype="used"]';
	} else if ( $mainType == 'out' ) {
		$buf .= '[ekptcomcontents_coupon limit=5 tid=2 maintype="out"]';
	}
	$html .= do_shortcode($buf);
	$html .= '</div>';
	$html .= '<div class="clear"></div>' ;
	return $html;
}

