		$bUpdParams['del_trade_item_d_seq_no'] = $vdata['seq_no'] ;
		$addUrl = _ekptcom_qshfItemTrade( $bUpdParams, 0 ) ;
		//
		$display_vdata = ekpt_get_item_info($vdata) ;
		//
		$html .= '<ul class="item-list">' ;
		$html .= '<li class="list-three"><div class="list-three-outer" style="">' ;
		$html .= '<div class="list-three-left">' ;
		$html .= '<img src="'.$display_vdata['display_image_url01'].'" alt="'.$display_vdata['display_item_title'].'" />' ;
		$html .= '</div>' ;
		$html .= '<div class="list-three-center"><ul>' ;
		if ( $vdata['type_label']  == 'ベース' ) {
			$html .= ekpt_get_item_display_html($vdata, $display_vdata);
		} else if ( $vdata['type_label']  == '素材') {
           	$html .= '<li>'.$display_vdata['display_item_title'].'</li>' ;
            if ( $vdata['category_label'] == 'エクポチケット' ) {
               $html .= '<li>所有個数:'.$mem_info['numof_ticket'].'枚'.'</li>' ;               
            } else {
               $html .= '<li>所有個数:'.$vdata['num_of_item'].'個'.'</li>' ;               
            }
		}
		// ボタン部の設定
		$html .= '</ul>' ;
		$html .= '</div>' ;
		$html .= '<div class="list-three-right">';
		$html .= '<a href="' . esc_html($baseurl.$bParams['current_uri'].'/'.$addUrl) . '">やめる</a><br>';
		$html .= '</div>' ;
		$html .= '</div></li>' ;
		$html .= '</ul><br>' ;

	}
	//
	$addUrl = _ekptcom_qshfItemTrade( $bParams, 0 ) ;
	if (count($vdatas) > 0) $html .= '[button align="center" color="lightgreen" link="'.esc_html($baseurl.$type.$confirm.$addUrl).'"]上のｱｲﾃﾑで出品を申請する[/button]<br>';
    return do_shortcode($html) ;
}

