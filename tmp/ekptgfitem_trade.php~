		$wqSeqnoArray = explode(',',$bParams['trade_item_d_seq_nos']) ;
		foreach ( $wqSeqnoArray as $wqSeqno ) {
			if ( (int) $bParams['new_trade_item_d_seq_no'] <> (int)$wqSeqno ) {
