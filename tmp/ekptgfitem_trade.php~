// 内部関数：　homeitemfusion 用： http用クエリ文字列を作る
function _ekptcom_qshfItemTrade( $bParams, $mktype = 0 ) {
	if ( count($bParams) == 0 ) { $bParams = $GLOBALS['EKPT_PARAM_ITEMTRADE'] ; }
	$qs = '' ;
	unset($bParams['json_status']) ;
	unset($bParams['json_error']) ;
	unset($bParams['base_url']) ;
	unset($bParams['home_url']) ;
	unset($bParams['current_uri']) ;
	if ( $mktype == 1 ) {
		foreach ( $bParams as $vk => $vv ) {
			$qs .= '<input type="hidden" name="' . $vk . '" value="' . $vv . '">';
		}
	} else {
		$qs = '?' . http_build_query($bParams) ;
	}
	return $qs ;
}
