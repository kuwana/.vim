/**
 * 交換所 成立・破棄
 */
function contents_tradeitem_done($atts = array()) {
	// Initialized.
	$bParams = $GLOBALS['EKPT_PARAM_ITEMTRADE'];
	$html = '';
	$jdatas = array();
	$vdatas = array();
	// Get paramaters.
	$mem_id = ekpt_get_opt('EKPTUSER');
    $baseurl = ekpt_get_opt('EKPTGFHOME'); 
	$trade_item_seq_no = $bParams['trade_item_seq_no'] ;
	$apply_item_seq_no = $bParams['apply_item_seq_no'] ;
	$reply = $bParams['trade_apply_reply'] ;
	// Set paramaters.
	$btn_home = _ekptcom_returnItemTrade() ;
	// 交換の実行orキャンセル
	if ($reply == 'yes') {
		$paramsYes = array(
			'trade_item_seq_no' => $trade_item_seq_no,
			'apply_item_seq_no' => $apply_item_seq_no,
			'reply' => $reply
		);
		$jdatas = ekpt_trade_get_json('exec_trade_item', $paramsYes);
		$vdatas = $jdatas['tradeitems'];
		if ( $jdatas['status'] == 'ok' ) {
			$html .= '[callout]交換が完了しました。[/callout]';
		} else {
			$html .= '[callout]交換が完了できませんでした。'.$jdatas['error'].'[/callout]';
		}
	} else if ($reply == 'no') {
		$paramsNo = array(
			'cancel_trade_seq_no' => $trade_item_seq_no
		);
		$jdatas = ekpt_trade_get_json('cancel_trade_item', $paramsNo);
		$vdatas = $jdatas['trade_item_list'];
		if ( $jdatas['status'] == 'ok' ) {
			$html .= '[callout]出品をキャンセルしました。[/callout]';
		} else {
			// print_r($jdatas) ;
			$html .= '[callout]出品をキャンセルできませんでした。'.$jdatas['error'].'[/callout]';
		}
	} else if ($reply == 'applyreject') {
		$paramsNo = array(
			'reject_apply_seq_nos' => $apply_item_seq_no
		);
		$jdatas = ekpt_trade_get_json('reject_apply_trade', $paramsNo);
		$vdatas = $jdatas['trade_item_list'];
		if ( $jdatas['status'] == 'ok' ) {
			$html .= '[callout]交換申請を断りました。[/callout]';
		} else {
			// print_r($jdatas) ;
			$html .= '[callout]交換申請を断ることができませんでした。'.$jdatas['error'].'[/callout]';
		}
	} else if ($reply == 'applycancel') {
		$paramsNo = array(
			'cancel_apply_seq_nos' => $apply_item_seq_no
		);
		$jdatas = ekpt_trade_get_json('cancel_apply_trade', $paramsNo);
		$vdatas = $jdatas['trade_item_list'];
		if ( $jdatas['status'] == 'ok' ) {
			$html .= '[callout]交換申請をキャンセルしました。[/callout]';
		} else {
			// print_r($jdatas) ;
			$html .= '[callout]交換申請をキャンセルできませんでした。'.$jdatas['error'].'[/callout]';
		}
	}
	$html .= $btn_home ;
	return do_shortcode($html);
}
