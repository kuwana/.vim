/**
 * 交換所 他ユーザーのアイテム出品一覧
 */
function contents_tradeitem_index() {
    // 属性を取り出す
    extract(shortcode_atts(array(
        'item_type' => 1,
    ), $atts));
    // 基本設定
	$mem_info = $GLOBALS['EKPTMEMINFO'];
    $baseurl  = ekpt_get_opt('EKPTGFHOME'); 
    $type     = 'homeitemtrade';
	$list     = '/sendlist';
	$ownlist  = '/tradeownlist';
	$html     = '';
	// パラメタ設定
	$GLOBALS['EKPT_ITEM_OWNS'] = array() ;
	$mem_id = ekpt_get_opt("EKPTUSER") ;
	// 出品アイテム一覧取得
	$param = array('startrec' => '1', 'limitofrec' => '300'); // sql側でlimit切ってあります
	$arrdata = ekpt_trade_get_json('get_trade_item_list', $param);
	$vdatas = $arrdata['trade_item_list'];
	$GLOBALS['EKPT_ITEM_OWNS'] = $vdatas;
	$opturl = ekpt_get_link_param();
	$html .= do_shortcode('[button align="center" color="lightgreen" link="' . esc_html($baseurl.$type.$list.$opturl) . '"]アイテムを交換所に出品する[/button]');
	$html .= do_shortcode('[callout] 交換所の出品一覧です[/callout]');
	//
	$html .= '<ul class="list-items">' ;
	$html .= '<li class="list-three"><div class="list-three-outer">' ;
	$html .= '<div class="list-three-left" >出品者</div>';
	$html .= '<div class="list-three-center" style="height:30px;">出品情報</div>' ;
	$html .= '<div class="list-three-right" style="height:30px;">操作</div>' ;
	$html .= '</div>&nbsp;</li></ul>' ;
	foreach ($vdatas as $vdata) {
		// ユーザー情報取得
		$param = array('mem_id' => $vdata['mem_id']);
		$arrdata2 = ekpt_get_json('get_memitemown_index', $param);
		$opturl = ekpt_get_link_param($param);
		$ownitems = $arrdata2['memitemowns'];
		$trade_no = explode(',', $vdata['trade_no']);
		$count = count($trade_no);
		// 画像生成
		$img = ''; // 画像を連結していく
		$i   =  0; // 表示制限の為のincrement変数
		foreach ($ownitems as $item) {
			if ($item['status'] == 's') {
				$img .= '<img class="alignnone size-thumbnail wp-image-136" width="60" height="60"';
				$img .= ' title="' . $item['image_url01'] . '"';
				$img .= ' style="margin: auto 5px;"';
				$img .= ' src="' . $baseurl . 'wp-content/uploads/2012/08/' . $item['image_url01'] . '"';
				$img .= ' alt="'.$item['item_title'] . '" />';

				$i++; // 表示制限
				if ($i > 2) {
					$img .= '<span style="color: #999;">+' . ($count - 3) . '</span>';
					break;
				}
			}
		}
		// レンダリング
		$html .= '<ul class="list-items">' ;
		$html .= '<li class="list-two"><div class="list-two-outer">' ;
		$html .= '<div class="list-two-left style="width:25%"">';
		$html .= '名前：'.$meminfo['mem_name'].'('.$item['rare_label'].')<br><p>ユーザー画像</p></div>';
		$html .= '<div class="list-two-right"> . $img .<a href="' . esc_html($baseurl.$type.$ownlist.$opturl) . '">交換を申込む></a></div>' ;
		$html .= '</div>&nbsp;</li></ul>' ;
	}

    return $html ;
	
}

