// Left関数//左からn文字取得して返す
function myLeft($str,$n){
	if(mb_strlen($str,"utf-8") <= $n){
		return $str;
	}else{
		return mb_substr($str,0,(mb_strlen($str,"utf-8")-$n)*-1,"utf-8");
	}
}


// Right関数//右からn文字取得して返す
function myRight($str,$n){
	return mb_substr($str,($n)*-1);
}

