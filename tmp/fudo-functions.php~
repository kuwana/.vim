function get_shop_images($path, $slug) {
	$maxlen = 12;  // filename length of limit
	$items = $list = array();
	$target = opendir($path);

	while (false !== $item = readdir($target)) {
		if ($item == '.' || $item == '..')  continue;
		if (is_dir($path.'/'.$item)) {
			$items = get_shop_images($path.'/'.$item, $slug);
			$list = array_merge($list, $items);
		} else {
			if (strlen($item) > $maxlen || strpos($item, $slug) === false)  continue;
			$dirs = explode('/', $path);
			$len = count($dirs);
			$path = get_bloginfo('url').'/wp-content/uploads/'.$dirs[$len-2].'/'.$dirs[$len-1];
			$list[] = $path.'/'.$item;
		}
	}
	closedir($target);

	return $list;
}

