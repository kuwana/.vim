function session_save($session_id, $userInfo = array()) {

	global $wpdb;

	if ($userInfo) {
		$wp_session = $wpdb->query($wpdb->prepare("
			INSERT INTO session (session_id, nickname, member_pic_url, created, ekpt_token) VALUES ('%s','%s','%s',now(),'%s')
			", $session_id, $userInfo['nickname'], $userInfo['member_pic_url'], $userInfo['token']));

		$res = $wpdb->prepare("
			\n INSERT INTO session (session_id, nickname, member_pic_url, created, ekpt_token) VALUES ('%s','%s','%s',now(),'%s')
			", $session_id, $userInfo['nickname'], $userInfo['member_pic_url'], $userInfo['token']);

		if ( ! $wp_session) {
			trigger_error('ログイン失敗: DBに問題があります。');
			return false;
		}
	}

	return true;
}
// セッション(token)破棄
function session_delete() {

	global $wpdb;

	// CookieとSession削除
	$ok_1 = $ok_2 = $ok = false;

	$_SESSION = array();

	setcookie('ekpt_session_id', '', time() - 3600);

	if (isset($_COOKIE[session_name()])) {
		$ok_1 = setcookie(session_name(), '', time() - 3600, '/');
	}
	$ok_2 = session_destroy();

	if($ok_1 && $ok_2) {
		header('Location: '.get_bloginfo('url'));
		exit;
	} else {
		$ok = false;
	}

	return false;
}
