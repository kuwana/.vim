// ユーザーの投票チェック(いいね、お気に入り)
// 初アクションかどうかチェック, 初ならAPIとDB Insert実行
// TODO: 後にAPI化する
function check_vote($mem_id, $shop_id, $action_type) {

	global $wpdb;

	// パラメタ設定
	if ($mem_id == '1' && empty($GLOBALS['ekpt_token'])) {
		$mem_id = '0';
	}
	if ($action_type == 'L') {
		//$param = array('FromMemId' => $mem_id, 'ToMemId' => $shop_id);
		$param = array('mem_id' => $mem_id, 'target_id' => $shop_id, 'type' => 1);
		$sendurl = EKPTDEF_HOME ;
		$arrdata = ekpt_get_json('/Api/sendLike', $param, $sendurl);
		$vdata = $arrdata['response']['data'];

		// 一日のいいねできる制限回数を越えた
		if ($arrdata['response']['status_code'] == 400) {
			// リジェクトDB (C = Cancel)
			$wp_updatelike = $wpdb->query($wpdb->prepare("
				UPDATE user_do SET action_type = %s WHERE FromMemId = %d AND ToMemId = %d
				", 'C', $shop_id, $mem_id));

			return $arrdata['response'];
		}

	} else if ($action_type == 'F') {
		$param = array('FromMemId' => $mem_id, 'ToMemId' => $shop_id, 'MessageText' => 'from exca');
		$sendurl = EKPTDEF_HOME ;
		$arrdata = ekpt_get_json('/Api/becomeFriend', $param, $sendurl);
		if ($arrdata['status'] === 'success') {
			$vdata['seq_no'] = 0;
		} else if ($arrdata['response'] == 'Both IDs are already friend.') {
			$vdata = 'already';
		} else {
			$vdata = false;
		}
	}

	return $vdata;

}
