function save_service_summary($post_id) {
	if ( isset($_POST['service_summary_nonce']) ) {
		if ( !wp_verify_nonce( $_POST['service_summary_nonce'], plugin_basename(__FILE__) ) ) {
			return $post_id;
		}
		if ( isset($_POST['post_type']) && 'fudo' == $_POST['post_type'] ) {
			if ( !current_user_can( 'edit_page', $post_id )) return $post_id;
		} else {
			if ( !current_user_can( 'edit_post', $post_id )) return $post_id;
		}

		$point_rate = isset($_POST['point_rate']) ? $_POST['point_rate'] : '5';
		$preopen_flag = isset($_POST['preopen']) ? $_POST['preopen'] : '';
		$point_flag = isset($_POST['point']) ? $_POST['point'] : 'coupon';
		$service_type_data = isset($_POST['service_type']) ? implode(',', $_POST['service_type']) : '';
		$coupon_type_data = isset($_POST['coupon_type']) ? implode(',', $_POST['coupon_type']) : '';

		// point_rate
		if ($point_rate != get_post_meta($post_id, 'shuuhensonota', true))
			update_post_meta($post_id, 'shuuhensonota', $point_rate);
		elseif ($point_rate == '')
			delete_post_meta($post_id, 'shuuhensonota', get_post_meta($post_id,'shuuhensonota',true));
		// preopen_flag
		if ($preopen_flag != get_post_meta($post_id, 'shozaichimeisho', true))
			update_post_meta($post_id, 'shozaichimeisho', $preopen_flag);
		elseif ($preopen_flag == '')
			delete_post_meta($post_id, 'shozaichimeisho', get_post_meta($post_id,'shozaichimeisho',true));
		// point_flag
		if ($point_flag != get_post_meta($post_id, 'tatemonomenseki', true))
			update_post_meta($post_id, 'tatemonomenseki', $point_flag);
		elseif ($point_flag == "")
			delete_post_meta($post_id, 'tatemonomenseki', get_post_meta($post_id,'tatemonomenseki',true));
		// service_type
		if (strcmp($service_type_data, get_post_meta($post_id, 'tatemonozentaimenseki', true)) != 0 )
			update_post_meta($post_id, 'tatemonozentaimenseki', $service_type_data);
		elseif ($service_type_data == "")
			delete_post_meta($post_id, 'tatemonozentaimenseki', get_post_meta($post_id,'tatemonozentaimenseki',true));
		// coupon_type
		if (strcmp($coupon_type_data, get_post_meta($post_id, 'tatemonokentikumenseki', true)) != 0 )
			update_post_meta($post_id, 'tatemonokentikumenseki', $coupon_type_data);
		elseif ($coupon_type_data == "")
			delete_post_meta($post_id, 'tatemonokentikumenseki', get_post_meta($post_id,'tatemonokentikumenseki',true));
	} else {
			return $post_id;
	}
}

