function ekpt_istown_login( $urldef = '', $param = array(),  $base_url = '' ) {

    if ( $base_url == '' ) {
        $base_url = ekpt_get_opt('EKPTHOMEAPICHECKTOKEN') ;
    }

    $search_url = $base_url . $urldef . "/";
    $retdata = array() ;
    //apiから検索結果をjsonでもらう
    $timeout = 30;
    ekpt_log_message($search_url) ;
    // if ( WP_DEBUG ) print_r($param);
    $ch = curl_init();
    curl_setopt( $ch, CURLOPT_URL, $search_url );
    curl_setopt( $ch, CURLOPT_HEADER, false );
    curl_setopt( $ch, CURLOPT_RETURNTRANSFER, true );
    curl_setopt( $ch, CURLOPT_POST, 1);
    if ( is_array($param) && count($param) > 0) {
            curl_setopt( $ch, CURLOPT_POSTFIELDS, $param);
    }
    curl_setopt( $ch, CURLOPT_TIMEOUT, $timeout );
    // SSL対応
    curl_setopt($ch, CURLOPT_SSL_VERIFYPEER, FALSE); // サーバ証明書検証をスキップ
    curl_setopt($ch, CURLOPT_SSL_VERIFYHOST, FALSE); // サーバ証明書検証をスキップ
    //
    $json = curl_exec( $ch );
    curl_close( $ch );

    //もらったjsonを連想配列に変換
    // print_r($param);
    if ( $json ) {
        $retdata = json_decode( $json , true );
    }
    // print_r($retdata) ;
    return $retdata ;
}

// ログインチェック
function ekpt_login($cookie = false) {

	global $post;

	// 変数初期化
	$ok = true ;
	$resArr = false;
	$token = '' ;
	$ret = array() ;
	$GLOBALS['ekpt_session_id'] = '';
	$GLOBALS['ekpt_token'] = '' ;
	$GLOBALS['ekpt_mem_id'] = '' ;
	$GLOBALS['ekpt_nickname'] = '' ;
	$GLOBALS['ekpt_image'] = '' ;
    $GLOBALS['ekpt_token_reply'] = array() ;

	// ログインチェック
	if ( $cookie ) {

		$resArr = get_session($cookie);

		if ( isset($resArr['ekpt_token'])) {

			$param = array('token' => $resArr['ekpt_token']);
			$ret = ekpt_istown_login('',$param) ;

			if ( !isset( $ret['status'] ) || $ret['status'] != 0 ) {
				$resArr = false ;
			} else {
				// if ( WP_DEBUG ) print_r($ret) ;
				$ret_data = $ret['data'] ;
				$GLOBALS['ekpt_session_id'] = $cookie;
				$GLOBALS['ekpt_token'] = $resArr['ekpt_token'] ;
				$GLOBALS['ekpt_mem_id'] = $ret_data['mem_id'] ;
				$GLOBALS['ekpt_nickname'] = $ret_data['nickname'] ;
				$GLOBALS['ekpt_image'] = $ret_data['image'] ;
				$GLOBALS['ekpt_token_reply'] = $ret_data ;
			}
		}
	}

	return $resArr ;
}

