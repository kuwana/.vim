function save_shop_summary($post_id) {
	if ( isset($_POST['shop_summary_nonce']) ) {
		if ( !wp_verify_nonce( $_POST['shop_summary_nonce'], plugin_basename(__FILE__) ) ) {
			return $post_id;
		}
		if ( isset($_POST['post_type']) && 'fudo' == $_POST['post_type'] ) {
			if ( !current_user_can( 'edit_page', $post_id )) return $post_id;
		} else {
			if ( !current_user_can( 'edit_post', $post_id )) return $post_id;
		}

		$restaurant_flag = isset($_POST['restaurant']) ? $_POST['restaurant'] : '';
		$no_course_flag = isset($_POST['no_course']) ? $_POST['no_course'] : '';
		$minimums_flag = isset($_POST['minimums']) ? $_POST['minimums'] : '';
		$purpose_data = isset($_POST['purpose']) ? implode(',', $_POST['purpose']) : '';
		$genre = isset($_POST['genre']) ? $_POST['genre'] : '';
		$budget = isset($_POST['budget']) ? $_POST['budget'] : '';

		// shop_id
		// -> admin_fudo.phpにて処理

		// restaurant_flag
		if ($restaurant_flag != get_post_meta($post_id, 'tatemonochikunenn', true))
			update_post_meta($post_id, 'tatemonochikunenn', $restaurant_flag);
		elseif ($restaurant_flag == '')
			delete_post_meta($post_id, 'tatemonochikunenn', get_post_meta($post_id,'tatemonochikunenn',true));
		// no_course_flag
		if ($no_course_flag != get_post_meta($post_id, 'no_course', true))
			update_post_meta($post_id, 'no_course', $no_course_flag);
		elseif ($no_course_flag == '')
			delete_post_meta($post_id, 'no_course', get_post_meta($post_id,'no_course',true));
		// minimums_flag
		if ($minimums_flag != get_post_meta($post_id, 'minimums', true))
			update_post_meta($post_id, 'minimums', $minimums_flag);
		elseif ($minimums_flag == '')
			delete_post_meta($post_id, 'minimums', get_post_meta($post_id,'minimums',true));
		// purpose_data
		if (strcmp($purpose_data, get_post_meta($post_id, 'madorisu', true)) != 0)
			update_post_meta($post_id, 'madorisu', $purpose_data);
		elseif ($purpose_data == '')
			delete_post_meta($post_id, 'madorusu', get_post_meta($post_id,'madorisu',true));
		// genre
		if (strcmp($genre ,get_post_meta($post_id, 'madorisyurui', true)) != 0)
			update_post_meta($post_id, 'madorisyurui', $genre);
		elseif ($genre == '')
			delete_post_meta($post_id, 'madorisyurui', get_post_meta($post_id,'modorisyurui',true));
		// budget
		if (strcmp($budget ,get_post_meta($post_id, 'kakakukoushin', true)) != 0)
			update_post_meta($post_id, 'kakakukoushin', $budget);
		elseif ($budget == '')
			delete_post_meta($post_id, 'kakakukoushin', get_post_meta($post_id,'modorisyurui',true));
	} else {
		return $post_id;
	}
}

