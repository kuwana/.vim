<?php

require_once('wp-load.php');
global $wpdb;

echo "========= START =========\n";

$sql = "select ID, post_name from $wpdb->posts where post_type='fudo' and post_status='publish'";
$allshops = $wpdb->get_results( $sql );

foreach( $allshops as $shop ) {

	$ID    = $shop->ID;
	$alias = $shop->post_name;

	$updateSQL = "update $wpdb->posts set post_password = '$alias$ID' where ID = $ID";

	$res = $wpdb->get_results( $updateSQL );
	if ($res)
		echo $updateSQL . "\nQuery OK.\n";
	else
		echo $updateSQL . "\nERROR.\n";
}

echo "========= DONE =========\n";
