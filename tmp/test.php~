<?php

class FizzBuzz {

	public static function main($argv) {

		// $argc => コマンドライン引数の数
		// $argv => コマンドライン引数が格納された配列

		for ($i = 1; $i <= $argv; $i++) {

			if ($i % 3 == 0 && $i % 5 == 0) {
				echo "fizzbuzz\n";
			}
			else if ($i % 3 == 0) {
				echo "fizz\n";
			}
			else if ($i % 5 == 0) {
				echo "buzz\n";
			}
			else {
				echo $i . "\n";
			}

		}
	}
}


FizzBuzz::main($argv[1]);
