#/bin/bash
ALIAS=$1
if [ -x "`which mogrify`" ]; then
  mogrify -format jpg *.tif
	mogrify -format jpg *.tiff
	mogrify -format jpg *.gif
	mogrify -format jpg *.png
  mogrify -format jpg *.eps
fi

ls *.jpg *.JPG *.JPEG *.jpeg | awk '{
	arr[1]="a";
	arr[2]="b";
	arr[3]="c";
	arr[4]="d";
	arr[5]="e";
	arr[6]="f";
	arr[7]="g";
	arr[8]="h";
	arr[9]="i";
	arr[10]="j";
	arr[11]="k";
	arr[12]="l";
	arr[13]="m";
	arr[14]="n";
	arr[15]="o";
	arr[16]="p";
	arr[17]="q";
	arr[18]="r";
	arr[19]="s";
	arr[20]="t";
	arr[21]="u";
	arr[22]="v";
	arr[23]="w";
	arr[24]="x";
	arr[25]="y";
	arr[26]="z";
	}
	{
		if (NR <= 26)
			printf "mv %s '$ALIAS'%s.jpg\n", $0, arr[NR]
		else if (NR <= 52)
			printf "mv %s '$ALIAS'%s.jpg\n", $0, "a" arr[NR-26]
		else if (NR <= 78)
			printf "mv %s '$ALIAS'%s.jpg\n", $0, "b" arr[NR-52]
		else
			printf "mv %s '$ALIAS'%s.jpg\n", $0, NR-78
	}' | sh
