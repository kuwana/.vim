#!/bin/bash

# define function

cp_to_uploads ()
{
	while read i
	do
		echo '↓'
		cp $i ../uploads/$(echo $i | sed 's/\///g' | sed 's/^\.//g' | sed 's/JPG/jpg/g')
		ls ../uploads
	done
	
	exit 0
}
resize_other ()
{
	while read i
	do
		echo 'resize to 300x300' $i
		width=`identify -format "%W" $i`
		height=`identify -format "%H" $i`

		if [ $width -ge $height ]; then
			mogrify -geometry x300 -gravity center -crop 300x300+0+0 $i
		elif [ $width -lt $height ]; then
			mogrify -geometry 300x -gravity center -crop 300x300+0+0 $i
		fi
	done

	exit 0

}
resize_oblong ()
{
	while read j
	do
		echo 'resize to 400x250' $j
		width=`identify -format "%W" $j`
		height=`identify -format "%H" $j`

		if [ $width -ge $height ]; then
			mogrify -geometry x400 -gravity center -crop 400x250+0+0 $j
		elif [ $width -lt $height ]; then
			mogrify -geometry 400x -gravity center -crop 400x250+0+0 $j
		fi
	done

	exit 0

}

