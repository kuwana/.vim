<?php
require_once('../../wp-config.php');
require_once('../../wp-settings.php');
require_once('../../wp-admin/includes/image.php');

global $wpdb;
$wpdb = new wpdb(DB_USER, DB_PASSWORD, DB_NAME, DB_HOST);
$wp_prefix = 'wp_';
$wpdb->posts = $wp_prefix.$wpdb->tables[0];
$wpdb->comments = $wp_prefix.$wpdb->tables[1];
$wpdb->links = $wp_prefix.$wpdb->tables[2];
$wpdb->options = $wp_prefix.$wpdb->tables[3];
$wpdb->postmeta = $wp_prefix.$wpdb->tables[4];
$wpdb->terms = $wp_prefix.$wpdb->tables[5];
$wpdb->term_taxonomy = $wp_prefix.$wpdb->tables[6];
$wpdb->term_relationships = $wp_prefix.$wpdb->tables[7];
$wpdb->commentmeta = $wp_prefix.$wpdb->tables[8];
$wpdb->users = $wp_prefix.$wpdb->global_tables[0];
$wpdb->usermeta = $wp_prefix.$wpdb->global_tables[1];

$wp_upload_dir = wp_upload_dir();
$uploaddir = $wp_upload_dir['basedir'].$wp_upload_dir['subdir'];
$dir = opendir($uploaddir);
$reg = '!^[a-z][0-9]+[a-z]{1,2}|oblong\.jpg$!';

while (false !== $filename = readdir($dir)) {

	if (!preg_match($reg, $filename))  continue;
	$wp_filetype = wp_check_filetype(basename($filename), null);
	$uploadfile = $uploaddir. '/' . basename( $filename );
	$attachment = array(
		'guid' => $wp_upload_dir['url'].'/'.$filename,
		'post_mime_type' => $wp_filetype['type'],
		'post_title' => preg_replace('/\.[^.]+$/', '', basename($filename)),
		'post_content' => '',
		'post_status' => 'inherit'
	);
	// check image existed.
	$q = $wpdb->prepare("SELECT ID FROM $wpdb->posts WHERE post_title = %s", $attachment['post_title']);
	$attach_id = $wpdb->get_var($q);
	if (!$attach_id) {
		// insert new image into wp_posts.
		$attach_id = wp_insert_attachment( $attachment, $uploadfile);
	} else {
		$ok = update_attached_file( $attach_id, $uploadfile );
	}
	// create resized images.
	$attach_data = wp_generate_attachment_metadata( $attach_id, $uploadfile);
	// insert resized images of metadata.
	wp_update_attachment_metadata( $attach_id, $attach_data );

	echo $filename.'を処理しました'."\n";
}
closedir($dir);

// attached images to post.
$q1 = $wpdb->prepare("SELECT ID, post_name FROM $wpdb->posts WHERE post_type = 'fudo' AND post_status in ('private', 'publish') ORDER BY post_name");
$r1 = $wpdb->get_results($q1);
foreach ($r1 as $p) {
	$q2 = $wpdb->prepare("UPDATE $wpdb->posts SET post_parent = %d WHERE post_type = 'attachment' AND post_title LIKE %s", $p->ID, $p->post_name.'%');
	$r2 = $wpdb->query($q2);
}

$q3 = $wpdb->prepare("SELECT ID, post_name FROM $wpdb->posts WHERE post_type = 'fudo' AND post_status = 'publish' ORDER BY post_name");
$r3 = $wpdb->get_results($q3);
$arr=array('a','b','c','d','e','f','g','h','i','j','k','l','m','n','o','p','q','r','s','t','u','v','w','x','y','z','aa','ab','ac','ad','ae','af','ag','ah','ai','aj','ak');
foreach ($r3 as $p) {
	for ($i = 1; $i <= 37; $i++) {
		//error_log(var_export(array($p->ID,'fudoimg'.$i, $p->post_name.$arr[$i-1]),true));
		update_post_meta($p->ID, 'fudoimg'.$i, $p->post_name.$arr[$i-1].'.jpg');
	}
}
?>
